{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chronicle:system-settings",
  "title": {
    "en": "System Settings",
    "zh": "系统设置"
  },
  "x-lang": "en",
  "x-version": "1.0.0",
  "x-migrations": [],
  "type": "object",
  "x-nav": {
    "group": "system",
    "icon": "settings",
    "order": 2,
    "tabs": {
      "system-appearance": {
        "icon": "palette",
        "order": 1,
        "label": {
          "en": "Appearance",
          "zh": "外观"
        }
      },
      "system-build": {
        "icon": "rocket",
        "order": 2,
        "label": {
          "en": "Build & Deploy",
          "zh": "构建与部署"
        }
      }
    }
  },
  "properties": {
    "backendTheme": {
      "type": "string",
      "default": "dark",
      "enum": [
        "light",
        "dark",
        "follow"
      ],
      "x-widget": "select",
      "x-tab": "system-appearance",
      "x-group": "theme",
      "x-order": 1,
      "title": {
        "en": "Backend Theme",
        "zh": "后台主题"
      },
      "x-options": [
        {
          "value": "light",
          "label": {
            "en": "Light",
            "zh": "浅色"
          }
        },
        {
          "value": "dark",
          "label": {
            "en": "Dark",
            "zh": "深色"
          }
        },
        {
          "value": "follow",
          "label": {
            "en": "Follow System",
            "zh": "跟随系统"
          }
        }
      ]
    },
    "backendAccent": {
      "type": "string",
      "default": "#2ea35f",
      "x-widget": "color",
      "x-tab": "system-appearance",
      "x-group": "theme",
      "x-order": 2,
      "title": {
        "en": "Backend Accent Color",
        "zh": "后台强调色"
      }
    },
    "backendFont": {
      "type": "string",
      "default": "sans",
      "enum": [
        "sans",
        "serif",
        "mono"
      ],
      "x-widget": "select",
      "x-tab": "system-appearance",
      "x-group": "theme",
      "x-order": 2,
      "title": {
        "en": "Backend Font",
        "zh": "后台字体"
      },
      "x-options": [
        {
          "value": "sans",
          "label": {
            "en": "Sans-serif",
            "zh": "无衬线体"
          }
        },
        {
          "value": "serif",
          "label": {
            "en": "Serif",
            "zh": "衬线体"
          }
        },
        {
          "value": "mono",
          "label": {
            "en": "Monospace",
            "zh": "等宽字体"
          }
        }
      ]
    },
    "backendLocale": {
      "type": "string",
      "default": "en",
      "enum": [
        "en",
        "zh-CN",
        "ja",
        "ko"
      ],
      "x-widget": "select",
      "x-tab": "system-appearance",
      "x-group": "locale",
      "x-order": 1,
      "title": {
        "en": "Backend Language",
        "zh": "后台语言"
      },
      "x-options": [
        {
          "value": "en",
          "label": {
            "en": "English",
            "zh": "English"
          }
        },
        {
          "value": "zh-CN",
          "label": {
            "en": "中文 (简体)",
            "zh": "中文 (简体)"
          }
        },
        {
          "value": "ja",
          "label": {
            "en": "日本語",
            "zh": "日本語"
          }
        },
        {
          "value": "ko",
          "label": {
            "en": "한국어",
            "zh": "한국어"
          }
        }
      ]
    },
    "backendBackground": {
      "type": "object",
      "x-widget": "background-editor",
      "x-tab": "system-appearance",
      "x-group": "background",
      "x-order": 1,
      "title": {
        "en": "Backend Background",
        "zh": "后台背景"
      },
      "x-meta": true
    },
    "backendBackgroundMeta": {
      "type": "string",
      "x-widget": "hidden",
      "x-tab": "system-appearance",
      "x-group": "background",
      "x-order": 2,
      "title": {
        "en": "Background Meta",
        "zh": "背景元数据"
      }
    },
    "backendBackgroundCompression": {
      "type": "number",
      "default": 12.96,
      "minimum": 1,
      "maximum": 30,
      "x-widget": "range",
      "x-tab": "system-appearance",
      "x-group": "background",
      "x-order": 3,
      "x-range": {
        "min": 1,
        "max": 30,
        "step": 0.1
      },
      "title": {
        "en": "Background Compression",
        "zh": "背景压缩"
      }
    },
    "frontendCodeDir": {
      "type": "string",
      "default": "/opt/Chronicle/packages/template-astro",
      "x-widget": "input",
      "x-tab": "system-build",
      "x-group": "paths",
      "x-order": 1,
      "x-advanced": true,
      "title": {
        "en": "Frontend Code Location",
        "zh": "前端代码目录"
      }
    },
    "frontendBuildTargetDir": {
      "type": "string",
      "default": "/var/www/chronicle",
      "x-widget": "input",
      "x-tab": "system-build",
      "x-group": "paths",
      "x-order": 2,
      "x-advanced": true,
      "title": {
        "en": "Build Target Location",
        "zh": "构建目标目录"
      }
    },
    "autoBuildOnPublish": {
      "type": "boolean",
      "default": true,
      "x-widget": "toggle",
      "x-tab": "system-build",
      "x-group": "triggers",
      "x-order": 1,
      "title": {
        "en": "Auto-build on Publish",
        "zh": "发布时自动构建"
      },
      "description": {
        "en": "Automatically trigger a frontend build when a post is published.",
        "zh-CN": "发布文章时自动触发前台构建。"
      }
    },
    "buildGranularity": {
      "type": "string",
      "default": "full",
      "enum": [
        "full",
        "posts",
        "index"
      ],
      "x-widget": "select",
      "x-tab": "system-build",
      "x-group": "triggers",
      "x-order": 2,
      "title": {
        "en": "Build Granularity",
        "zh": "构建粒度"
      },
      "x-options": [
        {
          "value": "full",
          "label": {
            "en": "Full Build",
            "zh": "完整构建"
          }
        },
        {
          "value": "posts",
          "label": {
            "en": "Posts Only",
            "zh": "仅文章"
          }
        },
        {
          "value": "index",
          "label": {
            "en": "Index Only",
            "zh": "仅索引"
          }
        }
      ]
    },
    "scheduledBuildEnabled": {
      "type": "boolean",
      "default": false,
      "x-widget": "toggle",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 1,
      "title": {
        "en": "Scheduled Build",
        "zh": "定时构建"
      },
      "description": {
        "en": "Enable scheduled cron-based frontend builds.",
        "zh-CN": "启用基于 cron 的定时前台构建。"
      }
    },
    "scheduledBuildMode": {
      "type": "string",
      "default": "daily",
      "enum": [
        "hourly",
        "daily",
        "weekly",
        "cron"
      ],
      "x-widget": "select",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 2,
      "x-visible-when": {
        "scheduledBuildEnabled": true
      },
      "title": {
        "en": "Schedule Mode",
        "zh": "定时模式"
      },
      "x-options": [
        {
          "value": "hourly",
          "label": {
            "en": "Hourly",
            "zh": "每小时"
          }
        },
        {
          "value": "daily",
          "label": {
            "en": "Daily",
            "zh": "每天"
          }
        },
        {
          "value": "weekly",
          "label": {
            "en": "Weekly",
            "zh": "每周"
          }
        },
        {
          "value": "cron",
          "label": {
            "en": "Custom Cron",
            "zh": "自定义"
          }
        }
      ]
    },
    "scheduledBuildMinute": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "maximum": 59,
      "x-widget": "number",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 3,
      "x-visible-when": {
        "scheduledBuildEnabled": true,
        "scheduledBuildMode": [
          "daily",
          "weekly"
        ]
      },
      "title": {
        "en": "Minute",
        "zh": "分钟"
      }
    },
    "scheduledBuildHour": {
      "type": "integer",
      "default": 3,
      "minimum": 0,
      "maximum": 23,
      "x-widget": "number",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 4,
      "x-visible-when": {
        "scheduledBuildEnabled": true,
        "scheduledBuildMode": [
          "daily",
          "weekly"
        ]
      },
      "title": {
        "en": "Hour",
        "zh": "小时"
      }
    },
    "scheduledBuildWeekday": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "maximum": 6,
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "x-widget": "select",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 5,
      "x-visible-when": {
        "scheduledBuildEnabled": true,
        "scheduledBuildMode": "weekly"
      },
      "title": {
        "en": "Weekday",
        "zh": "星期"
      },
      "x-options": [
        {
          "value": 0,
          "label": {
            "en": "Sunday",
            "zh": "星期日"
          }
        },
        {
          "value": 1,
          "label": {
            "en": "Monday",
            "zh": "星期一"
          }
        },
        {
          "value": 2,
          "label": {
            "en": "Tuesday",
            "zh": "星期二"
          }
        },
        {
          "value": 3,
          "label": {
            "en": "Wednesday",
            "zh": "星期三"
          }
        },
        {
          "value": 4,
          "label": {
            "en": "Thursday",
            "zh": "星期四"
          }
        },
        {
          "value": 5,
          "label": {
            "en": "Friday",
            "zh": "星期五"
          }
        },
        {
          "value": 6,
          "label": {
            "en": "Saturday",
            "zh": "星期六"
          }
        }
      ]
    },
    "scheduledBuildCron": {
      "type": "string",
      "default": "0 3 * * *",
      "x-widget": "input",
      "x-tab": "system-build",
      "x-group": "schedule",
      "x-order": 6,
      "x-visible-when": {
        "scheduledBuildEnabled": true,
        "scheduledBuildMode": "cron"
      },
      "title": {
        "en": "Custom Cron",
        "zh": "自定义 Cron"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scheduledBuildEnabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "scheduledBuildMode"
        ]
      }
    }
  ],
  "x-groups": {
    "paths": {
      "label": {
        "en": "Paths",
        "zh": "路径"
      }
    },
    "schedule": {
      "label": {
        "en": "Schedule",
        "zh": "定时"
      }
    },
    "triggers": {
      "label": {
        "en": "Build Triggers",
        "zh": "构建触发"
      }
    },
    "locale": {
      "label": {
        "en": "Language & Region",
        "zh": "语言与地区"
      }
    },
    "theme": {
      "label": {
        "en": "Theme",
        "zh": "主题"
      }
    },
    "background": {
      "label": {
        "en": "Background",
        "zh": "背景"
      }
    }
  }
}