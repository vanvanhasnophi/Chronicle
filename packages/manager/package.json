{
  "name": "@chronicle/manager",
  "private": true,
  "version": "2.0.0",
  "description": "Chronicle CMS — Markdown editor, content manager, and site settings",
  "author": { "name": "Eightyfor", "email": "j13811593@163.com" },
  "homepage": "https://github.com/vanvanhasnophi/Chronicle",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:dev": "vue-tsc -b && vite build",
    "build": "node --max_old_space_size=1536 ../../node_modules/.bin/vite build",
    "preview": "vite preview",
    "electron:install": "npm install electron electron-builder --save-dev",
    "electron:dev": "kill $(lsof -ti :5173) 2>/dev/null || true; ELECTRON=true NODE_ENV=development vite --port 5173 & sleep 4 && NODE_ENV=development electron . --dev",
    "electron:build": "ELECTRON=true vite build && npx electron-builder",
    "electron:start": "npx electron ."
  },
  "build": {
    "appId": "top.eightyfor.chronicle-manager",
    "productName": "Chronicle Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "j13811593@163.com"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "katex": "^0.16.28",
    "lucide-vue-next": "^0.269.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^10.1.0",
    "vue": "^3.5.18",
    "vue-i18n": "^9.3.2",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vue-tsc": "^3.0.5"
  }
}
