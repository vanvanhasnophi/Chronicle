{
  "name": "@chronicle/manager",
  "private": true,
  "version": "2.1.1",
  "description": "Chronicle CMS — Markdown editor, content manager, and site settings",
  "author": {
    "name": "Eightyfor",
    "email": "j13811593@163.com"
  },
  "homepage": "https://github.com/vanvanhasnophi/Chronicle",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:dev": "vue-tsc -b && vite build",
    "build": "node --max_old_space_size=1536 ../../node_modules/.bin/vite build",
    "preview": "vite preview",
    "electron:install": "npm install electron electron-builder --save-dev",
    "electron:dev": "kill $(lsof -ti :5173) 2>/dev/null || true; ELECTRON=true NODE_ENV=development vite --port 5173 & sleep 4 && NODE_ENV=development electron . --dev --no-sandbox",
    "electron:build": "ELECTRON=true vite build && npx electron-builder",
    "electron:start": "npx electron . --no-sandbox"
  },
  "build": {
    "appId": "top.eightyfor.chronicle-manager",
    "productName": "Chronicle Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "dompurify": "^3.4.9",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.28",
    "lucide-vue-next": "^0.269.0",
    "markdown-it": "^14.2.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^10.1.0",
    "pptxgenjs": "^4.0.1",
    "vue": "^3.5.18",
    "vue-i18n": "^9.3.2",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vue-tsc": "^3.0.5"
  }
}
