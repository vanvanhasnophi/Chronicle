{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chronicle:collections",
  "title": {
    "en": "Collections",
    "zh-CN": "合集管理"
  },
  "x-lang": "en",
  "x-version": "2.0.2",
  "x-migrations": [],
  "type": "array",
  "x-chronicle-class": "collection-tree",
  "x-nav": {
    "group": "template",
    "tabs": {
      "": {
        "label": {
          "en": "Collections",
          "zh-CN": "合集管理"
        },
        "icon": "folder-tree",
        "order": 4
      }
    }
  },
  "items": {
    "type": "object",
    "required": [
      "name",
      "slug"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 60,
        "x-widget": "input",
        "x-order": 1,
        "title": {
          "en": "Name",
          "zh": "名称"
        }
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "minLength": 1,
        "maxLength": 60,
        "x-widget": "input",
        "x-order": 2,
        "title": {
          "en": "Slug",
          "zh": "别名"
        }
      },
      "description": {
        "type": "string",
        "maxLength": 300,
        "x-widget": "textarea",
        "x-order": 3,
        "title": {
          "en": "Description",
          "zh": "描述"
        }
      },
      "cover": {
        "type": "string",
        "x-widget": "image-picker",
        "x-order": 4,
        "title": {
          "en": "Cover",
          "zh": "封面"
        }
      },
      "nodes": {
        "type": "array",
        "x-widget": "node-tree",
        "x-order": 5,
        "items": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "type",
                "id"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "const": "post",
                  "x-widget": "hidden"
                },
                "id": {
                  "type": "string",
                  "x-widget": "post-picker"
                }
              }
            },
            {
              "type": "object",
              "required": [
                "type",
                "title"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "const": "group",
                  "x-widget": "hidden"
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "x-widget": "input"
                },
                "children": {
                  "type": "array",
                  "x-widget": "node-tree",
                  "items": {
                    "$ref": "#/items/properties/nodes/items"
                  }
                }
              }
            }
          ]
        },
        "title": {
          "en": "Nodes",
          "zh": "节点"
        }
      }
    }
  }
}