---
import Layout from '../layouts/Layout.astro';
import { getLocale, getTranslation } from '../utils/i18n';
import { buildLocalizedPath } from '../utils/routeLocale';
import { loadSiteSettings } from '../utils/siteSettings';

export const prerender = true;

const locale = getLocale(Astro.locals);
const t = (key: string) => getTranslation(locale, key);
const isZh = locale === 'zh-CN';
const homeHref = buildLocalizedPath(locale, '/');
const blogsHref = buildLocalizedPath(locale, '/blogs');
const searchHref = buildLocalizedPath(locale, '/search');

const settings = await loadSiteSettings();
---

<Layout 
  title={isZh ? '页面未找到' : 'Page not found'}
  settings={settings}
  locale={locale}
  meta={{
    title: isZh ? '页面未找到' : 'Page not found',
    description: isZh ? '你访问的页面不存在，或者已经被移动。' : 'The page you requested does not exist or has been moved.',
    robots: 'noindex,nofollow',
    noIndex: true,
  }}
  scrollable={false}
>
  <main class="error-shell">
    <div class="error-copy">
      <p class="error-eyebrow">404</p>
      <h1 id="error-title">{isZh ? '页面未找到' : 'Page not found'}</h1>
      <p class="error-lead">
        {isZh
          ? '你访问的页面不存在，或者已经被移动。'
          : 'The page you requested does not exist or has been moved.'}
      </p>

      <div class="error-actions">
        <a class="error-action" href={homeHref}>{isZh ? '返回首页' : 'Go home'}</a>
        <a class="error-action" href={blogsHref}>{isZh ? '浏览文章' : 'Browse posts'}</a>
        <a class="error-action" href={searchHref}>{isZh ? '搜索内容' : 'Search'}</a>
      </div>

      <p class="error-footnote">
        {isZh
          ? '如果你是从旧链接进入，试试首页或搜索。'
          : 'If you followed an old link, try the home page or search.'}
      </p>
    </div>
  </main>

  <style>
    .error-shell {
      min-height: calc(100vh - 70px);
      display: grid;
      place-items: center;
      padding: clamp(1.5rem, 4vw, 4rem);
      box-sizing: border-box;
      color: var(--app-text-primary);
    }

    .error-copy {
      width: min(100%, 720px);
      transform: translateY(-20%);
    }

    .error-eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: .22em;
      color: var(--component-text-secondary);
      font-size: .8rem;
    }

    .error-copy h1 {
      margin: 1rem 0;
      font-size: clamp(2rem, 4.5vw, 3.6rem);
      line-height: 1;
      letter-spacing: -.02em;
    }

    .error-lead {
      margin: 0;
      max-width: 42rem;
      color: var(--component-text-secondary);
      font-size: 1rem;
      line-height: 1.8;
    }

    .error-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .7rem;
      margin-top: .75rem;
    }

    .error-action {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: .5rem 1rem;
      border-radius: 12px;
      border: 1px solid var(--border-color-blur);
      background: var(--component-bg-blur-alt);
      color: var(--app-text-primary);
      text-decoration: none;
      font-weight: 600;
      transition: background .18s ease, border-color .18s ease;
    }

    .error-action:hover {
      background: var(--component-bg-hover);
      border-color: color-mix(in srgb, var(--accent-color) 42%, var(--border-color-blur));
    }

    .error-footnote {
      margin: 1rem 0 0;
      color: var(--component-text-secondary);
      font-size: .92rem;
      line-height: 1.55;
    }

    @media (max-width: 640px) {
      .error-shell {
        padding: 1rem;
      }

      .error-actions {
        flex-direction: column;
      }

      .error-action {
        width: 100%;
      }
    }
  </style>
</Layout>