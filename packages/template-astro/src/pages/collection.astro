---
import Layout from '../layouts/Layout.astro';
import { resolveFeatureFlags } from '../utils/featureFlags';
import { loadSiteSettings } from '../utils/siteSettings';
import { getCollections, getPublishedPosts } from '../data/localDataSource';

// 直接暴露 /collection，客户端根据 pathname 推断本地化前缀
export const prerender = true;

const settings = await loadSiteSettings();
const featureFlags = resolveFeatureFlags((settings as any)?.featureFlags);

// ── Local data: embed collections + posts for client-side use ──
let embeddedCollections: any[] = [];
let embeddedPostTitles: Record<string, string> = {};
try {
  const collectionsData = getCollections();
  embeddedCollections = (collectionsData as any)?.collections || [];
  const posts = getPublishedPosts();
  for (const p of posts) {
    embeddedPostTitles[String(p.id)] = String(p.title || '').trim();
  }
} catch (e) {
  console.error('[collection] Failed to load local data:', e);
}

---

<Layout settings={settings}>
  <main class="collection-page main-content">
    <div class="collection-shell">
      <section class="layer-list" id="collection-list-layer">
        <h2 class="section-title">Collections</h2>
        <div class="collections-grid" id="collections-grid" aria-label="Collections"></div>
      </section>

      <section class="layer-detail" id="collection-detail-layer" style="display:none;">
        <div class="detail-header">
          <button class="back-btn" id="collection-back-btn" type="button">Back to collections</button>
        </div>
        <h1 id="collection-title">Collection</h1>
        <p id="collection-desc"></p>
        <div id="collection-tree" class="collection-tree"></div>
      </section>
    </div>
  </main>

  <style is:global>
    .collection-shell { max-width: 900px; margin: 0 auto; padding: 40px; color: var(--text-primary); box-sizing: border-box; }
    .section-title { font-size: 1.8em; margin: 0 0 24px; color: var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 10px; }
    .collections-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .collection-card-link { text-decoration: none; color: inherit; }
    .post-card.collection-card { padding: 16px; background: var(--component-bg-blur-alt); border: 1px solid var(--border-color-blur); border-radius: 8px; cursor: pointer; transition: transform 0.2s, border-color 0.2s; }
    .post-card.collection-card:hover { transform: translateY(-2px); border-color: var(--component-text-primary-highlight); }
    .collection-card-title { font-size: 1.1em; margin: 0 0 8px; font-weight: 600; color: var(--component-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .collection-card-desc { margin: 0; color: var(--component-text-secondary); font-size: 0.92em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .detail-header { margin-bottom: 12px; }
    .back-btn { background: transparent; border: 1px solid var(--border-color); color: var(--component-text-secondary); border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    .back-btn:hover { color: var(--component-text-primary-highlight); border-color: var(--component-text-primary-highlight); }
    .layer-detail #collection-title { margin: 0 0 8px; color: var(--component-text-primary); }
    .layer-detail #collection-desc { margin: 0 0 16px; color: var(--component-text-secondary); }
    .collection-tree {
      background: transparent;
      border: none;
      border-radius: 0;
      padding: 0;
    }
    .mini-card {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 8px;
      background: transparent;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background 0.12s ease, transform 0.08s ease, border-color 0.12s ease;
    }
    .mini-card:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 12%, transparent); }
    .mini-card.post { background: rgba(0,0,0,0); }
    .mini-card.group-header { font-weight: 600; color: var(--component-text-primary); }
    .mini-card .caret { width: 18px; height: 18px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px; background:transparent; border:0; color:var(--component-text-secondary); margin-left: auto; }
    .mini-card .mini-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1 1 auto; }
    .mini-icon { width: 18px; height: 18px; display:inline-flex; align-items:center; justify-content:center; margin-right: 8px; color: var(--component-text-secondary); flex: 0 0 18px; }
    .mini-icon svg { display: block; width: 18px !important; height: 18px !important; }
    .children-container { margin-left: 12px; border-left: none; padding-left: 12px; }
    .children-container[hidden] { display: none; }

    .mini-card.group-header:hover { background: var(--component-bg-highlight); border-color: var(--component-text-primary-highlight); transform: translateY(-1px); }
    .mini-card.group-header.active { background: color-mix(in srgb, var(--accent-color) 6%, var(--component-bg)); border-color: var(--accent-color); }
    .mini-card.post:hover { background: var(--component-bg-hover); border-color: var(--border-color); transform: translateY(-1px); }
    .mini-card .caret svg { transition: transform 120ms linear; transform-origin: center; display: block !important; width: 18px !important; height: 18px !important; }
    .mini-card .caret.expanded svg { transform: rotate(90deg); }
    .mini-card .caret { min-width: 18px; min-height: 18px; padding: 0; }
    .collection-tree ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .collection-tree li {
      margin: 8px 0;
      position: relative;
    }
    .collection-tree strong {
      color: var(--component-text-primary);
      font-weight: 600;
      font-variation-settings: 'wght' 600;
      display: inline-block;
      margin-bottom: 2px;
    }
    .collection-tree a {
      color: var(--accent-color);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .collection-tree a:hover {
      color: var(--component-text-primary-hover);
      border-bottom-color: currentColor;
    }
    @media (max-width: 768px) {
      .collection-shell { padding: 20px 14px; }
      .collections-grid { grid-template-columns: 1fr; gap: 10px; }
      .post-card.collection-card { border-radius: 12px; padding: 12px 14px; }
      .post-card.collection-card:hover { transform: none; background: var(--component-bg-hover); }
    }
  </style>

  <!-- Embedded data for local/static mode -->
  <script id="chronicle-embedded-data" type="application/json">
    {JSON.stringify({ collections: embeddedCollections, postTitles: embeddedPostTitles })}
  </script>

  <script>
    // @ts-nocheck
    (function () {
      // Check for embedded build-time data (local/static mode)
      const embeddedEl = document.getElementById('chronicle-embedded-data');
      const embeddedData = embeddedEl ? JSON.parse(embeddedEl.textContent || '{}') : null;
      const hasEmbedded = embeddedData && Array.isArray(embeddedData.collections) && embeddedData.collections.length > 0;

      let initialized = false;
      let collections = [];
      let postTitleById = new Map();

      // Pre-populate from embedded data
      if (hasEmbedded) {
        collections = embeddedData.collections;
        if (embeddedData.postTitles) {
          Object.entries(embeddedData.postTitles).forEach(([id, title]) => {
            postTitleById.set(id, (title as string) || id);
          });
        }
      }

      function formatCollectionName(name) {
        return String(name || '').replace(/[-_]+/g, ' ').trim() || defaultTitle;
      }

      function resolvePostTitle(postId) {
        const id = String(postId || '');
        return postTitleById.get(id) || id;
      }

      function safeDecodeHash(hash) {
        try {
          if (!hash) return '';
          if (hash.startsWith('#')) hash = hash.slice(1);
          return decodeURIComponent(hash);
        } catch (e) {
          return '';
        }
      }

      function initCollectionPage() {
        const listLayerEl = document.getElementById('collection-list-layer');
        const detailLayerEl = document.getElementById('collection-detail-layer');
        const gridEl = document.getElementById('collections-grid');
        const backBtn = document.getElementById('collection-back-btn');
        const titleEl = document.getElementById('collection-title');
        const descEl = document.getElementById('collection-desc');
        const treeEl = document.getElementById('collection-tree');
        if (!listLayerEl || !detailLayerEl || !gridEl || !backBtn || !titleEl || !descEl || !treeEl) return;

        const routePrefix = location.pathname.includes('/zh') ? '/zh' : '/en';
        const defaultTitle = 'Collection';

        function showListLayer() {
          listLayerEl.style.display = '';
          detailLayerEl.style.display = 'none';
        }

        function showDetailLayer() {
          listLayerEl.style.display = 'none';
          detailLayerEl.style.display = '';
        }

        function renderCollectionCards() {
          gridEl.innerHTML = '';
          collections.forEach((c) => {
            const link = document.createElement('a');
            link.className = 'collection-card-link';
            link.href = `#${encodeURIComponent(c.name)}`;
            link.setAttribute('data-collection-name', c.name);

            const card = document.createElement('article');
            card.className = 'post-card collection-card';

            const title = document.createElement('h3');
            title.className = 'collection-card-title';
            title.textContent = formatCollectionName(c.name);

            const desc = document.createElement('p');
            desc.className = 'collection-card-desc';
            desc.textContent = c.description || '';

            card.appendChild(title);
            card.appendChild(desc);
            link.appendChild(card);
            gridEl.appendChild(link);
          });
        }

        function clearDetail() {
          titleEl.textContent = defaultTitle;
          descEl.textContent = '';
          treeEl.innerHTML = '';
        }

        function renderTreeNodes(container, nodes) {
          if (!nodes || !Array.isArray(nodes)) return;
          const ul = document.createElement('ul');
          nodes.forEach((node) => {
            const li = document.createElement('li');
            li.className = node.type === 'group' ? 'node-group' : 'node-post';

            if (node.type === 'post') {
              const card = document.createElement('div');
              card.className = 'mini-card post';
              card.tabIndex = 0;
              card.setAttribute('role', 'link');
              card.dataset.postId = node.id;
              const icon = document.createElement('span');
              icon.className = 'mini-icon';
              icon.innerHTML = '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" opacity="0.9"/></svg>';
              const title = document.createElement('span');
              title.className = 'mini-title';
              title.textContent = resolvePostTitle(node.id);
              card.appendChild(icon);
              card.appendChild(title);
              li.appendChild(card);
            } else if (node.type === 'group') {
              const header = document.createElement('div');
              header.className = 'mini-card group-header';
              header.tabIndex = 0;
              header.setAttribute('role', 'button');
              header.dataset.type = 'group';

              const icon = document.createElement('span');
              icon.className = 'mini-icon';
              icon.innerHTML = '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>';

              const title = document.createElement('span');
              title.className = 'mini-title';
              title.textContent = node.title || node.name || 'Group';
              header.appendChild(icon);
              header.appendChild(title);

              const caret = document.createElement('button');
              caret.className = 'caret';
              caret.type = 'button';
              caret.setAttribute('aria-hidden', 'true');
              caret.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>';
              header.appendChild(caret);

              li.appendChild(header);

              const childrenWrap = document.createElement('div');
              childrenWrap.className = 'children-container';
              childrenWrap.hidden = true;
              if (Array.isArray(node.children)) renderTreeNodes(childrenWrap, node.children);
              li.appendChild(childrenWrap);
            }

            ul.appendChild(li);
          });
          container.appendChild(ul);
        }

        function showCollectionByName(name) {
          clearDetail();
          if (!name) {
            showListLayer();
            return;
          }
          const found = collections.find((c) => c.name === name);
          if (!found) {
            showListLayer();
            return;
          }
          titleEl.textContent = formatCollectionName(found.name);
          descEl.textContent = found.description || '';
          renderTreeNodes(treeEl, found.nodes);
          showDetailLayer();
        }

        function handleHash() {
          const raw = safeDecodeHash(location.hash);
          if (!raw) {
            showCollectionByName('');
            return;
          }
          const exists = collections.some((c) => c.name === raw);
          if (!exists) {
            showCollectionByName('');
            return;
          }
          showCollectionByName(raw);
        }

        async function load() {
          // Use embedded build-time data if available (local/static mode)
          if (hasEmbedded) {
            renderCollectionCards();
            handleHash();
            return;
          }

          try {
            const [collectionRes, postsRes] = await Promise.all([
              fetch('/api/collections?t=' + Date.now(), { cache: 'no-store' }),
              fetch('/api/posts?t=' + Date.now(), { cache: 'no-store' }),
            ]);
            if (!collectionRes.ok) throw new Error('fetch collections failed');
            const data = await collectionRes.json();
            // Unwrap { code, data, message } API response format
            const collData = (data && data.data) ?? data;
            collections = Array.isArray(collData.collections) ? collData.collections : [];

            postTitleById = new Map();
            if (postsRes.ok) {
              const postsData = await postsRes.json();
              const postsUnwrapped = (postsData && postsData.data) ?? postsData;
              const posts = Array.isArray(postsUnwrapped)
                ? postsUnwrapped
                : Array.isArray(postsUnwrapped?.posts)
                  ? postsUnwrapped.posts
                  : [];
              posts.forEach((post) => {
                const id = String(post?.id || '');
                const title = String(post?.title || '').trim();
                if (id) postTitleById.set(id, title || id);
              });
            }

            renderCollectionCards();
            handleHash();
          } catch (e) {
            console.error('Failed to load collections', e);
          }
        }

        if (!gridEl.dataset.bound) {
          gridEl.dataset.bound = '1';
          gridEl.addEventListener('click', (e) => {
            const target = e.target;
            const link = target && target.closest ? target.closest('.collection-card-link') : null;
            if (!link) return;
            e.preventDefault();
            const name = link.getAttribute('data-collection-name') || '';
            if (!name) return;
            // Render immediately so one click always opens detail, then sync URL hash.
            showCollectionByName(name);
            const nextHash = `#${encodeURIComponent(name)}`;
            if (location.hash !== nextHash) {
              history.replaceState(null, '', `${location.pathname}${location.search}${nextHash}`);
            }
          });
        }

        // Tree interactions: delegation for toggle and post activation
        if (!treeEl.dataset.bound) {
          treeEl.dataset.bound = '1';
          treeEl.addEventListener('click', (e) => {
            const hdr = e.target && e.target.closest ? e.target.closest('.group-header') : null;
            if (hdr) {
              const li = hdr.parentElement;
              const children = li && li.querySelector('.children-container');
              if (!children) return;
              const wasHidden = children.hidden;
              children.hidden = !wasHidden;
              const expanded = !children.hidden;
              const caret = hdr.querySelector('.caret');
              if (caret) caret.classList.toggle('expanded', expanded);
              hdr.classList.toggle('active', expanded);
              return;
            }

            const postCard = e.target && e.target.closest ? e.target.closest('.mini-card.post') : null;
            if (postCard) {
              const id = postCard.dataset.postId;
              if (!id) return;
              location.href = `${routePrefix}/post/${encodeURIComponent(id)}`;
            }
          });

          treeEl.addEventListener('keydown', (e) => {
            if (e.key !== 'Enter' && e.key !== ' ') return;
            const hdr = e.target && e.target.closest ? e.target.closest('.group-header') : null;
            if (hdr) {
              e.preventDefault();
              hdr.click();
              return;
            }
            const postCard = e.target && e.target.closest ? e.target.closest('.mini-card.post') : null;
            if (postCard) {
              e.preventDefault();
              postCard.click();
            }
          });
        }

        if (!backBtn.dataset.bound) {
          backBtn.dataset.bound = '1';
          backBtn.addEventListener('click', () => {
            history.replaceState(null, '', location.pathname + location.search);
            showCollectionByName('');
          });
        }

        if (!initialized) {
          initialized = true;
          window.addEventListener('hashchange', handleHash);
        }

        load();
      }

      document.addEventListener('astro:page-load', initCollectionPage);
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initCollectionPage();
      } else {
        document.addEventListener('DOMContentLoaded', initCollectionPage, { once: true });
      }
    })();
  </script>
</Layout>