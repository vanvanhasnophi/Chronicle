---
import { getLocale } from "../utils/i18n";

const locale = getLocale(Astro.locals);
const routePrefix = locale === "zh-CN" ? "/zh" : "/en";
const baseRedirectPath = `${routePrefix}/about`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting to About</title>
    <meta http-equiv="refresh" content={`0;url=${baseRedirectPath}`} />
  </head>
  <body>
    <script>
      const searchParams = window.location.search;
      const routePrefix = window.location.pathname.includes('/zh') ? '/zh' : '/en';
      const redirectPath = `${routePrefix}/about${searchParams}`;
      window.location.replace(redirectPath);
    </script>
    <div style="display:none;">
      <p>If you are not redirected, <a href={baseRedirectPath}>click here</a>.</p>
    </div>
  </body>
</html>
