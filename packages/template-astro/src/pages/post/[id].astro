---
import { getLocale } from "../../utils/i18n";
import { getApiUrl } from "../../config/api";
import { isLocalMode } from "../../core/site";

export async function getStaticPaths() {
  // ── Local data source ──────────────────────────────────
  if (isLocalMode) {
    const { getPublishedPosts } = await import("../../data/localDataSource");
    return getPublishedPosts().map((post: any) => ({
      params: { id: String(post.id) }
    }));
  }

  // ── Remote API ─────────────────────────────────────────
  try {
    const res = await fetch(getApiUrl('/api/posts', true), { cache: 'no-store' });
    if (res.ok) {
      const responseText = await res.text();
      let posts: any[] = [];

      try {
        const data = JSON.parse(responseText);
        posts = Array.isArray(data) ? data : (data.posts || []);
      } catch (parseError) {
        const jsonMatch = responseText.match(/\[.*\]/);
        if (jsonMatch) {
          try {
            posts = JSON.parse(jsonMatch[0]);
          } catch (e) {
            console.error('[Build] Manual JSON parse error:', e);
          }
        }
      }

      return posts.map((post: any) => ({
        params: { id: String(post.id) }
      }));
    }
  } catch (err) {
    console.error('[Build] Failed to fetch posts for static paths:', err);
  }

  return [];
}

// 获取当前语言设置
const locale = getLocale(Astro.locals);
const routePrefix = locale === "zh-CN" ? "/zh" : "/en";

// 获取当前URL的完整路径信息
const { id } = Astro.params;
const url = new URL(Astro.request.url);
const hash = url.hash; // 保留hash定位
const searchParams = url.search; // 保留查询参数

// 构建完整重定向路径，保留帖子ID、hash和查询参数
const redirectPath = `${routePrefix}/post/${id}${searchParams}${hash}`;

// 使用meta标签进行立即重定向，用户看不到任何页面
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting to Blogs</title>
    <!-- 立即重定向，用户看不到任何页面 -->
    <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
  </head>
  <body>
    <!-- 备用重定向，使用客户端JavaScript获取查询参数 -->
    <script>
      // 获取当前URL的查询参数和路径信息
      const searchParams = window.location.search;
      const hash = window.location.hash;
      const pathname = window.location.pathname;
      const routePrefix = window.location.pathname.includes('/zh') ? '/zh' : '/en';
      
      // 从路径中提取帖子ID
      const pathSegments = pathname.split('/').filter(Boolean);
      const postId = pathSegments[pathSegments.length - 1];
      
      // 构建完整重定向路径，保留帖子ID、查询参数和hash
      const redirectPath = `${routePrefix}/post/${postId}${searchParams}${hash}`;
      
      // 立即重定向
      window.location.replace(redirectPath);
    </script>
    <!-- 最终备用方案 -->
    <div style="display:none;">
      <p>If you are not redirected, <a href={redirectPath}>click here</a>.</p>
    </div>
  </body>
</html>