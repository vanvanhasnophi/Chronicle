---
import Layout from '../../../layouts/Layout.astro';
import { getPublishedPosts, getPostById, getPublicSettings, getCollections } from '../../../data/localDataSource';
import { getTranslation, getLocale } from '../../../utils/i18n';
import { buildLocalizedPath, toContentLocale } from '../../../utils/routeLocale';
import { buildTocItems, injectHeadingIds } from '../../../utils/toc';
import { renderCodeBlockStatsHtml, renderCodeBlockLangLabelsHtml } from '../../../utils/markdownParser';
import { escapeHtmlText, decodeHtmlEntities, getFileExt, getMediaIcon, toMediaCard, rewriteMediaLinks, hydrateLegacyKatexPlaceholders, wrapRenderedKatex } from '../../../utils/contentUtils';
import DesktopFloatingToc from '../../../components/FloatingToc.vue';
import MobileTocPanel from '../../../components/MobileTocPanel.vue';
import CornerActions from '../../../components/CornerActions.vue';
import CollectionNav from '../../../components/CollectionNav.vue';
import 'katex/dist/katex.min.css';
import '../../../styles/post.css';
import '@chronicle/shared/src/styles/chronicle-markdown.css';

export const prerender = true;

 



export async function getStaticPaths() {
  const posts = getPublishedPosts();
  return posts.flatMap((post) => ([
    { params: { lang: 'zh', id: String(post.id) } },
    { params: { lang: 'en', id: String(post.id) } },
  ]));
}

const routeLang = Astro.params.lang === 'en' ? 'en' : 'zh';
const locale = toContentLocale(routeLang);
const backToBlogs = buildLocalizedPath(routeLang, '/blogs');
const searchForTags = buildLocalizedPath(routeLang, '/search?tags=');
const t = (key: string) => getTranslation(locale, key);
const { id } = Astro.params;
const mermaidUiText = {
  downloadSvg: t('preview.mermaid.downloadSvg'),
  split: t('preview.mermaid.split'),
  code: t('preview.mermaid.code'),
  preview: t('preview.mermaid.preview'),
  notPrerendered: t('preview.mermaid.notPrerendered'),
};

let post: any = null;
let error = null;
let settings: Record<string, any> = {};

// ── Local data source ──────────────────────────────────
const localPost = getPostById(id);
if (localPost) {
  post = {
    id: localPost.id,
    title: localPost.title,
    date: localPost.date,
    updatedAt: localPost.updatedAt,
    tags: localPost.tags || [],
    summary: localPost.summary || '',
    content: localPost.content,
    html: localPost.compiledHtml,
    toc: localPost.toc || [],
    collection: localPost.collection,
    collectionPath: localPost.collectionPath,
    font: localPost.font,
    status: localPost.status,
  };
}
settings = getPublicSettings() as Record<string, any>;

// ── Collections + post titles for CollectionNav ──────────
let embeddedCollections: any[] = [];
let embeddedPostTitles: Record<string, string> = {};
try {
  const collectionsData = getCollections();
  embeddedCollections = (collectionsData as any)?.collections || [];
  const allPosts = getPublishedPosts();
  for (const p of allPosts) {
    embeddedPostTitles[String(p.id)] = String(p.title || '').trim();
  }
} catch (_) {}

if (!post && !error) {
  error = 'Post not found';
}

let pageTitle = 'Post not found';
if (post && post.title) {
  pageTitle = `${post.title}`;
}

const createdAtText = post ? new Date(post.date).toLocaleDateString(locale) : '';
const updatedAtText = post && post.updatedAt && post.updatedAt !== post.date
  ? new Date(post.updatedAt).toLocaleDateString(locale)
  : '';

// 计算字数和阅读时间
let wordCount = 0;
let readingTime = 0;

if (post && post.content) {
  // 移除HTML标签，只统计纯文本字数
  const textContent = post.content.replace(/<[^>]*>/g, '').trim();
  
  // 中文字数统计（每个中文字符算1个字）
  const chineseChars = (textContent.match(/[\u4e00-\u9fa5]/g) || []).length;
  
  // 英文单词统计（按空格分隔）
  const englishWords = textContent.replace(/[\u4e00-\u9fa5]/g, '').trim();
  const englishWordCount = englishWords ? englishWords.split(/\s+/).length : 0;
  
  // 总字数（中文字数 + 英文单词数）
  wordCount = chineseChars + englishWordCount;
  
  // 阅读时间估算（中文：300字/分钟，英文：200字/分钟）
  const chineseReadingTime = chineseChars / 300;
  const englishReadingTime = englishWordCount / 200;
  readingTime = Math.ceil(chineseReadingTime + englishReadingTime);
  
  // 最少1分钟
  if (readingTime < 1) readingTime = 1;
}

// 获取作者名和AI生成标记
const authorName = post?.author || settings?.authorName || 'Eightyfor';
const isAI = post?.aiGenerated || false;

function buildMetaDescription(input: any, fallbackLocale: string) {
  const fallback = fallbackLocale === 'zh-CN'
    ? '浏览 Chronicle 的文章详情。'
    : 'Read the Chronicle article details.';
  const rawSource = String(
    input?.summary ||
    input?.excerpt ||
    input?.description ||
    input?.content ||
    input?.html ||
    '',
  ).trim();

  if (!rawSource) return fallback;

  const plainText = rawSource
    .replace(/<[^>]*>/g, ' ')
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>')
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/\s+/g, ' ')
    .trim();

  if (!plainText) return fallback;
  return plainText.slice(0, 160) + (plainText.length > 160 ? '...' : '');
}

const rawPostHtml = typeof post?.html === 'string' ? post.html : '';
const rawPostMarkdown = typeof post?.content === 'string' ? post.content : '';
const renderContextLabel = `${post?.id || id || 'unknown-id'}${post?.title ? `:${post.title}` : ''}`;
let renderedPostContent = rawPostHtml
  ? hydrateLegacyKatexPlaceholders(rawPostHtml, renderContextLabel)
  : (rawPostMarkdown ? `<pre class="md-fallback">${escapeHtmlText(rawPostMarkdown)}</pre>` : '');

// Mermaid: rendered client-side on demand (requires browser DOM, not available at SSG build time)
// Toolbar HTML and mermaid-container placeholder are generated by renderCodeChunkHtml

let tocItems: any[] = [];

if (renderedPostContent) {
  console.info('[Post SSR] Rendering post content', {
    context: renderContextLabel,
    length: renderedPostContent.length,
    htmlSource: !!rawPostHtml,
  });
    try {
    // First apply server-side replacements that may affect headings (code footers, language labels)
    try {
      renderedPostContent = renderCodeBlockStatsHtml(renderedPostContent, locale)
      try { renderedPostContent = renderCodeBlockLangLabelsHtml(renderedPostContent, locale) } catch (e) {}
    } catch (e) {
      // ignore and keep placeholders
    }

    // Use server-provided TOC if available; fall back to local HTML heading extraction
    if (post && Array.isArray(post.toc) && post.toc.length > 0) {
      tocItems = buildTocItems('', true, post.toc);
    } else if (renderedPostContent) {
      tocItems = buildTocItems(renderedPostContent, true);
    } else {
      tocItems = [];
    }

    // Inject heading ids into rendered HTML so TOC links work
    if (tocItems.length > 0) {
      renderedPostContent = injectHeadingIds(renderedPostContent, tocItems);
    }
  } catch (renderErr) {
    // If rendering fails completely, fall back to escaped raw content
    console.error('[Post SSR] Rendering failed:', renderContextLabel, renderErr);
    renderedPostContent = `<div class="md-placeholder">文章内容渲染失败</div><pre style="margin-top:1rem; padding: 1rem; background: var(--component-bg-primary); border-radius: 4px; overflow-x: auto; font-size: 12px;">${escapeHtmlText((rawPostHtml || rawPostMarkdown).substring(0, 500))}</pre>`;
  }
}

const metaDescription = buildMetaDescription(post, locale);
---

<Layout title={pageTitle} settings={settings} locale={locale} navTitle={post?.title} navBackHref={backToBlogs} navBackLabel={t('inblog.backToBlogs')} meta={{ description: metaDescription, type: 'article' }}>
  <div class="post-detail-container" id="post-top">
    {error ? (
      <div class="error-container">
        <h1>Post not found</h1>
        <p>{error}</p>
        <a href={backToBlogs} class="back-link" aria-label="Back to blogs">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            {t('inblog.backToBlogs')}
        </a>
      </div>
    ) : post ? (
      <article class={`post-content font-${post.font || 'sans'}`}>
        <nav class="post-nav">
          <a href={backToBlogs} class="nav-back" aria-label="Back to blogs">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            {t('inblog.backToBlogs')}
          </a>
        </nav>

        <header class="post-header">
          <h1 class="post-title">{post.title}</h1>

          <div class="post-meta">
            <!-- 第一行：作者和创建修改时间 -->
            <div class="meta-row">
              <span class="meta-item" title={`Author: ${authorName}`} aria-label={`Author: ${authorName}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <span class="meta-value">{authorName}</span>
              </span>
              <span class="meta-item" title={createdAtText} aria-label={`Created ${createdAtText}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <span class="meta-label">{t('inblog.created')}</span>
                <time datetime={new Date(post.date).toISOString()}>{createdAtText}</time>
              </span>
              {updatedAtText && (
                <span class="meta-item" title={updatedAtText} aria-label={`Updated ${updatedAtText}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                  <span class="meta-label">{t('inblog.updated')}</span>
                  <time datetime={new Date(post.updatedAt).toISOString()}>{updatedAtText}</time>
                </span>
              )}
            </div>

            <!-- 第二行：字数和阅读时间 -->
            <div class="meta-row">
              {wordCount > 0 && (
                <span class="meta-item" title={`${wordCount} words`} aria-label={`${wordCount} words`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14,2 14,8 20,8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10,9 9,9 8,9"></polyline></svg>
                  <span class="meta-label">{t('inblog.words')}</span>
                  <span class="meta-value">{wordCount.toLocaleString()}</span>
                </span>
              )}
              {readingTime > 0 && (
                <span class="meta-item" title={`${readingTime} minutes read`} aria-label={`${readingTime} minutes read`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12,6 12,12 16,14"></polyline></svg>
                  <span class="meta-label">{t('inblog.readingTime')}</span>
                  <span class="meta-value">{readingTime} {t('inblog.min')}</span>
                </span>
              )}
            </div>

            <!-- 第三行：AI生成标记（如果有） -->
            {isAI && (
              <div class="meta-row">
                <span class="meta-item warning" title="AI Generated Content" aria-label="AI Generated Content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                  <span class="meta-label">{t('inblog.aiGeneratedTip')}</span>
                </span>
              </div>
            )}

            {post.tags && post.tags.length > 0 && (
              <div class="post-tags">
                {post.tags.map((tag: string) => (
                <a href={searchForTags + encodeURIComponent(tag)} class="tag-link" aria-label={`Search for tag ${tag}`}>
                  <span class="tag" class:list={[{ featured: tag === 'featured' || tag === '精选' }]} >
                    {tag}
                  </span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </header>

        {tocItems.length > 0 && (
          <details class="markdown-toc">
            <summary class="toc-summary" aria-label={t('inblog.toc-title')}>
              <span class="toc-title">{t('inblog.toc-title')}</span>
              <svg class="toc-toggle-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="toc-body">
              <ul class="toc-list">
                {tocItems.map((item) => (
                  <li class={`toc-level-${item.level}`}>
                    <a href={`#${item.id}`}>
                      <span class="toc-text">{item.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        )}

        <div class="post-body">
          <div class="chronicle-markdown md-parser-rendered markdown-content" set:html={renderedPostContent} />
        </div>
      </article>
    ) : null}
  </div>
  <div class="scroll-blank"/>

  {tocItems.length > 0 && (
    <>
      <DesktopFloatingToc
        client:idle
        toc={tocItems}
        navLabel={t('inblog.toc-title')}
        mountToBody={true}
      />
      <MobileTocPanel client:idle toc={tocItems} />
    </>
  )}

  {post?.collection && (
    <CollectionNav client:idle postId={post?.id || id} collections={embeddedCollections} postTitles={embeddedPostTitles} />
  )}

  <CornerActions client:idle hasToc={tocItems.length > 0} />

  <style is:global>
    @media (max-width: 768px) {
      .post-detail-container {
        padding: 1rem 0.5rem;
      }

      .post-title {
        font-size: 2rem;
      }

      .meta-row {
        flex-direction: column;
        gap: 0.5rem;
      }

      .post-nav {
        margin-bottom: 0;
      }

      .scroll-blank {
        height: 80px;
      }
    }
    

  </style>

  <script>
    // 复制代码功能 - 参考CodeChunk.vue实现
    function copyCode(button: HTMLElement) {
      const code = button.getAttribute('data-code');
      if (!code) return;

      // Optimistically show an in-progress state to reduce perceived delay
      showCopyInProgress(button);

      // Try modern Clipboard API first (async, but we don't await to keep UI responsive)
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        navigator.clipboard.writeText(code).then(() => {
          clearCopyInProgress(button);
          showCopySuccess(button);
        }).catch(() => {
          // Fallback to execCommand approach
          tryFallbackCopy(button, code);
        });
        return;
      }

      // Fallback immediately
      tryFallbackCopy(button, code);
    }

    function tryFallbackCopy(button: HTMLElement, code: string) {
      const textArea = document.createElement('textarea');
      textArea.value = code;
      // Place off-screen to avoid scroll
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        const successful = document.execCommand('copy');
        if (successful) {
          clearCopyInProgress(button);
          showCopySuccess(button);
        } else {
          clearCopyInProgress(button);
          console.error('Fallback copy failed');
        }
      } catch (backupErr) {
        clearCopyInProgress(button);
        console.error('复制失败:', backupErr);
      } finally {
        document.body.removeChild(textArea);
      }
    }
    
    // 显示复制成功状态
    function showCopySuccess(button: HTMLElement) {
      const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
      const successIcon = button.querySelector('.success-icon') as HTMLElement;
      
      if (copyIcon) copyIcon.style.display = 'none';
      if (successIcon) successIcon.style.display = 'block';
      button.classList.add('success');
      
      // 1.5秒后恢复原状
      setTimeout(() => {
        if (copyIcon) copyIcon.style.display = 'block';
        if (successIcon) successIcon.style.display = 'none';
        button.classList.remove('success');
      }, 1500);
    }
    
    function showCopyInProgress(button: HTMLElement) {
      const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
      if (copyIcon) copyIcon.style.opacity = '0.4';
      button.classList.add('copying');
    }

    function clearCopyInProgress(button: HTMLElement) {
      const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
      if (copyIcon) copyIcon.style.opacity = '';
      button.classList.remove('copying');
    }

    function initPostPageFeatures() {
      import('../../../utils/mathTooltip').then(({ initMathTooltip }) => {
        initMathTooltip(document.querySelector('.post-content'));
      }).catch((err) => {
        console.error('初始化数学公式 tooltip 失败:', err);
      });

      // Initialize special Mermaid code-block interactions (mode switch + SVG download)
      initMermaidCodeBlocks();

      // 初始化复制按钮
      const copyButtons = document.querySelectorAll('.copy-btn');
      copyButtons.forEach(button => {
        const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
        const successIcon = button.querySelector('.success-icon') as HTMLElement;

        if (copyIcon) copyIcon.style.display = 'block';
        if (successIcon) successIcon.style.display = 'none';
      });

      // 直接给每个 copy 按钮绑定处理器，避免 document 代理导致的额外查找开销
      copyButtons.forEach(button => {
        // Remove previous handlers if any to avoid duplication
        (button as HTMLElement).removeEventListener('click', (button as any).__copyHandler__);
        const handler = (e: Event) => {
          e.stopPropagation();
          copyCode(button as HTMLElement);
        };
        (button as any).__copyHandler__ = handler;
        (button as HTMLElement).addEventListener('click', handler);
      });

      const imageClickHandler = (event: Event) => {
        const target = event.target as HTMLElement | null;
        const img = target && target.closest ? target.closest('img.md-image') as HTMLImageElement | null : null;
        if (!img) return;
        const hook = (window as any).__CHRONICLE_OPEN_IMAGE_VIEWER__;
        if (typeof hook === 'function') {
          event.preventDefault();
          event.stopPropagation();
          hook({ src: img.src, alt: img.alt || '', element: img });
        }
      };

      const globalState = window as any;
      if (!globalState.__CHRONICLE_IMAGE_CLICK_HANDLER_BOUND__) {
        globalState.__CHRONICLE_IMAGE_CLICK_HANDLER_BOUND__ = true;
        document.addEventListener('click', imageClickHandler, { capture: true });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPostPageFeatures, { once: true });
    } else {
      initPostPageFeatures();
    }

    document.addEventListener('astro:page-load', initPostPageFeatures);
    
    // Google Analytics: post_view handling moved to standalone script below
    
    // Mermaid support for published read-only code blocks.
    // IMPORTANT: Astro side never renders Mermaid; we only consume server-prerendered SVG.

    function getMermaidUiText() {
      const w = (typeof window !== 'undefined') ? (window as any) : null;
      const fallback = {
        downloadSvg: 'Download SVG',
        split: 'Split View',
        code: 'Code Only',
        preview: 'Preview Only',
        notPrerendered: 'No prerendered Mermaid SVG found.'
      };
      if (!w || !w.__MERMAID_UI_TEXT) return fallback;
      const ui = w.__MERMAID_UI_TEXT;
      return {
        downloadSvg: String(ui.downloadSvg || fallback.downloadSvg),
        split: String(ui.split || fallback.split),
        code: String(ui.code || fallback.code),
        preview: String(ui.preview || fallback.preview),
        notPrerendered: String(ui.notPrerendered || fallback.notPrerendered)
      };
    }

    function makeIconButton(title: string, iconSvg: string, extraClass = '') {
      const btn = document.createElement('button');
      btn.className = `icon-btn ${extraClass}`.trim();
      btn.type = 'button';
      btn.title = title;
      btn.setAttribute('aria-label', title);
      btn.innerHTML = iconSvg;
      return btn;
    }

    function initMermaidCodeBlocks() {
      const ui = getMermaidUiText();
      const blocks = document.querySelectorAll('.code-chunk-container.mermaid');
      if (!blocks || blocks.length === 0) return;

      blocks.forEach((block: Element) => {
        if (!(block instanceof HTMLElement)) return;
        if (block.dataset.mermaidEnhanced === '1') return;

        const editorWrapper = block.querySelector('.editor-wrapper') as HTMLElement | null;
        const editorFooter = block.querySelector('.editor-footer') as HTMLElement | null;
        if (!(editorWrapper instanceof HTMLElement)) return;

        const textarea = block.querySelector('.code-textarea') as HTMLTextAreaElement | null;
        const codeText = textarea?.value || '';
        if (!codeText.trim()) return;

        block.dataset.mermaidEnhanced = '1';

        // Query existing DOM — toolbar + preview panel generated by SSG renderCodeChunkHtml
        const preview = block.querySelector('.mermaid-preview') as HTMLElement | null;
        const container = preview?.querySelector('.mermaid-container') as HTMLElement | null;
        let downloadBtn = block.querySelector('.mermaid-download-btn') as HTMLElement | null;
        let splitBtn   = block.querySelector('.mermaid-split-btn') as HTMLElement | null;
        let codeBtn    = block.querySelector('.mermaid-code-btn') as HTMLElement | null;
        let previewBtn = block.querySelector('.mermaid-preview-btn') as HTMLElement | null;

        // Pre-rendered SVG from SSG build
        const preSvg = container?.querySelector('svg');
        let lastRenderedSvg: string | null = preSvg ? preSvg.outerHTML : null;
        if (lastRenderedSvg && downloadBtn) (downloadBtn as HTMLButtonElement).disabled = false;

        let mode: 'split' | 'code' | 'preview' = 'preview';

        function setActiveButton() {
          splitBtn?.classList.toggle('active', mode === 'split');
          codeBtn?.classList.toggle('active', mode === 'code');
          previewBtn?.classList.toggle('active', mode === 'preview');
        }

        let mermaidRenderBusy = false;
        async function renderMermaidSvg() {
          if (mode === 'code' || !container) return;
          if (lastRenderedSvg) { container.innerHTML = lastRenderedSvg; return; }
          if (mermaidRenderBusy) return;
          mermaidRenderBusy = true;
          try {
            container.innerHTML = '<div class="mermaid-loading">Rendering…</div>';
            // @ts-ignore — dynamic import, resolved at runtime by Vite
            const mm = await import('mermaid');
            const mermaidLib = (mm as any).default || mm;
            mermaidLib.initialize({ startOnLoad: false, theme: 'base' });
            const id = 'mermaid_client_' + Math.random().toString(36).slice(2, 8);
            const { svg } = await mermaidLib.render(id, codeText);
            lastRenderedSvg = svg;
            container.innerHTML = svg;
            if (downloadBtn) (downloadBtn as HTMLButtonElement).disabled = false;
          } catch (e: any) {
            container.innerHTML = '<div class="mermaid-error">Mermaid render error</div>';
          } finally {
            mermaidRenderBusy = false;
          }
        }

        function applyMode(nextMode: 'split' | 'code' | 'preview') {
          mode = nextMode;
          setActiveButton();
          if (editorWrapper) editorWrapper.style.display = (mode === 'preview') ? 'none' : '';
          if (editorFooter) editorFooter.style.display = (mode === 'preview') ? 'none' : '';
          if (preview) preview.style.display = (mode === 'code') ? 'none' : '';
          if (mode !== 'code') {
            renderMermaidSvg();
          }
        }

        splitBtn?.addEventListener('click', () => applyMode('split'));
        codeBtn?.addEventListener('click', () => applyMode('code'));
        previewBtn?.addEventListener('click', () => applyMode('preview'));

        downloadBtn?.addEventListener('click', () => {
          if (!lastRenderedSvg) return;
          try {
            const raw = lastRenderedSvg;
            const parser = new DOMParser();
            const doc = parser.parseFromString(raw, 'image/svg+xml');
            const svgEl = doc.documentElement;

            // ensure defs
            let defs = svgEl.querySelector('defs');
            if (!defs) {
              defs = doc.createElementNS('http://www.w3.org/2000/svg', 'defs');
              svgEl.insertBefore(defs, svgEl.firstChild);
            }

            // clone global marker if exists
            try {
              const globalMarker = document.querySelector('marker#chronicle-mermaid-arrow');
              if (globalMarker) {
                const cloned = globalMarker.cloneNode(true);
                const existing = defs.querySelector('#chronicle-mermaid-arrow');
                if (existing) existing.remove();
                defs.appendChild(doc.importNode(cloned, true));
              }
            } catch (e) {}

            // inline resolved CSS variables for consistency
            try {
              const cs = getComputedStyle(document.documentElement);
              const vars = {
                '--component-bg-blur-alt': cs.getPropertyValue('--component-bg-blur-alt') || '#ffffff',
                '--border-color': cs.getPropertyValue('--border-color') || '#e6e6e6',
                '--text-primary': cs.getPropertyValue('--text-primary') || '#111111',
                '--component-text-primary': cs.getPropertyValue('--component-text-primary') || '#111111'
              };
              const styleContent = `
                svg { background: ${vars['--component-bg-blur-alt']}; }
                rect { fill: ${vars['--component-bg-blur-alt']}; stroke: ${vars['--text-primary']}; }
                path { stroke: ${vars['--component-text-primary']}; fill: none; }
                text { fill: ${vars['--component-text-primary']}; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif; }
              `;
              const prevStyle = svgEl.querySelector('style[data-chronicle-inline]');
              if (prevStyle) prevStyle.remove();
              const styleEl = doc.createElementNS('http://www.w3.org/2000/svg', 'style');
              styleEl.setAttribute('data-chronicle-inline', '1');
              styleEl.textContent = styleContent;
              svgEl.insertBefore(styleEl, svgEl.firstChild);
            } catch (e) {}

            const serializer = new XMLSerializer();
            const outSvg = serializer.serializeToString(svgEl);
            const blob = new Blob([outSvg], { type: 'image/svg+xml;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'mermaid-' + Date.now() + '.svg';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
          } catch (err) {
            // fallback
            const blob = new Blob([lastRenderedSvg], { type: 'image/svg+xml;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'mermaid-' + Date.now() + '.svg';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
          }
        });

        // default mode: preview
        if (!lastRenderedSvg && downloadBtn) (downloadBtn as HTMLButtonElement).disabled = true;
        applyMode('preview');
      });
    }

    // code block stats are rendered during SSR; no client-side hydration needed
  </script>

  <script define:vars={{ POST_ID: JSON.stringify(post?.id || id), POST_TITLE: JSON.stringify(post?.title || ''), PAGE_LOCALE: JSON.stringify(locale), MERMAID_UI_TEXT: JSON.stringify(mermaidUiText) }} is:inline>
    (function() {
      try {
        if (typeof window !== 'undefined') {
          window.__PAGE_LOCALE = PAGE_LOCALE;
          window.__MERMAID_UI_TEXT = MERMAID_UI_TEXT;
        }
      } catch(e) {}
      function sendPostView() {
        try {
          if (typeof window !== 'undefined' && typeof window.gtag === 'function') {
            window.gtag('event', 'post_view', { post_id: POST_ID, post_title: POST_TITLE, page_path: location.pathname });
          }
        } catch (e) {
          // ignore
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', sendPostView, { once: true });
      } else {
        sendPostView();
      }

      document.addEventListener('astro:page-load', sendPostView);
    })();
  </script>

  <script src="../../../utils/filePreviewLazy.js"></script>

</Layout>