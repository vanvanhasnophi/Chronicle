---
export const prerender = true;

export async function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

import Layout from "../../layouts/Layout.astro";
import SearchBox from "../../components/SearchBox.astro";
import { getTranslation, getLocale } from "../../utils/i18n.ts";
import { buildLocalizedPath } from "../../utils/routeLocale.ts";
import { sortTags } from "../../utils/tagUtils.ts";
import { getPublishedPosts, isLocalMode } from "../../data/localDataSource";
import { resolveFeatureFlags } from "../../utils/featureFlags.ts";
import { loadSiteSettings } from "../../utils/siteSettings";

const locale = getLocale(Astro.locals);
const t = (key: string) => getTranslation(locale, key);
const routePrefix = locale === "zh-CN" ? "/zh" : "/en";

const settings = await loadSiteSettings();

const featureFlags = resolveFeatureFlags(settings?.featureFlags);
const searchSuggestionsEnabled = featureFlags.searchSuggestions !== false;

// Fetch posts
interface Post {
  id: string;
  title: string;
  date: string;
  summary?: string;
  tags?: string[];
}

let posts: Post[] = [];

// ── Local data source ──────────────────────────────
try {
  posts = getPublishedPosts() as Post[];
} catch (e) {
  console.error('[search] Failed to load local posts:', e);
}

// Extract all tags with counts
const tagCounts = new Map<string, number>();
posts.forEach((p) => {
  p.tags?.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const allTagData = Array.from(tagCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => {
    if (a.name === "featured" || a.name === "精选") return -1;
    if (b.name === "featured" || b.name === "精选") return 1;
    return a.name.localeCompare(b.name);
  });

// ── Build search index for local/static mode ──────────
const searchIndex = posts.map(p => ({
  id: p.id,
  title: p.title,
  date: p.date,
  summary: p.summary || '',
  tags: p.tags || [],
}));

// Get URL params for initial state
const url = new URL(Astro.request.url);
// 支持新格式：?tags=tag1,tag2&keyword=搜索词
const keywordParam = url.searchParams.get("keyword") || "";
const tagsParam = url.searchParams.get("tags") || "";

// 处理旧格式兼容性
const initialTitle = keywordParam || url.searchParams.get("title") || "";
const initialTags = tagsParam ? tagsParam.split(",") : url.searchParams.getAll("tags");

// Tag cloud view: ?view=tags shows the full tag cloud directly
const resultsTitleText = t("search.resultsTitle");
const resultsCountText = t("search.resultsCount").replace("{count}", "0");
const metaDescription = locale === "zh-CN"
  ? "在 Chronicle 中按标题或标签搜索文章与内容。"
  : "Search Chronicle posts and content by title or tags.";
---

<Layout title={t("nav.search")} settings={settings} scrollable={false} meta={{ description: metaDescription }}>
  <div class="page-container centered-mode" id="search-page">
    <SearchBox
      instanceId="search-page-searchbox"
      searchSuggestionsEnabled={searchSuggestionsEnabled}
      showTagTrigger={true}
      initialTitle={initialTitle}
      featuredLabel={t("tag.featured")}
      routePrefix={routePrefix}
      t={t}
      searchOnEnter={true}
      searchBtnAsButton={true}

    />
        
    <div class="content-wrapper" id="content-wrapper" style="display:none;">
    {searchSuggestionsEnabled && (
    <div class="tag-cloud-container" id="tag-cloud" style="display:none;">
        <div
          class="selected-tags-header"
          id="selected-tags-header"
          style="display:none;"
        >
          <h3>{t("search.selectedTags")}</h3>
          <div class="selected-tags-list" id="selected-tags-list"></div>
        </div>
        <div class="content-scroll-area">
          <div class="tags-grid">
            {
              allTagData.map((tagData) => (
                <button
                  class="tag-cloud-item"
                  data-tag={tagData.name}
                  class:list={[
                    {
                      featured:
                        tagData.name === "featured" || tagData.name === "精选",
                    },
                  ]}
                >
                  {tagData.name === "featured" || tagData.name === "精选"
                    ? t("tag.featured")
                    : tagData.name}
                  <span class="tag-count">{tagData.count}</span>
                </button>
              ))
            }
          </div>
          <div
            class="cloud-btm-barrier"
            style="display:block; height:40px; background:transparent;"
          >
          </div>
        </div>
      </div>
      )}

      <div class="results-container" id="results-container">
        <div class="results-header" id="results-header" style="display:none;">
          <h3 id="results-title">{resultsTitleText}</h3>
          <span class="results-count" id="results-count">{resultsCountText}</span>
        </div>
        <div class="content-scroll-area">
          <div class="results-list" id="results-list">
            <div class="loading" id="loading-state">{t("search.loading")}</div>
            <div class="empty" id="empty-state" style="display:none;">
              {t("search.noResults")}
            </div>
            <div class="results-list" id="results-content"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .page-container {
    max-width: 800px;
    max-height: calc(100vh - 70px);
    margin: 0 auto;
    padding: 15vh 20px 0;
    color: var(--text-primary);
    height: 100vh;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
  }

  html.is-mobile .page-container{
    padding: 10px 15px 0;
  }

  /* Centered Mode */
  .page-container.centered-mode .search-box-wrapper {
    transform: translateY(20vh);
  }

  /* Centered Mode */
  html.is-mobile .page-container.centered-mode .search-box-wrapper {
    transform: translateY(30vh);
  }

  /* Results Fade Transition */
  .fade-enter-active {
    transition: opacity 0.6s ease 0.5s;
  }
  .fade-leave-active {
    transition: opacity 0.1s ease;
  }

  .fade-enter-from,
  .fade-leave-to {
    opacity: 0;
  }


.selected .tag-count {
    color: var(--recommended-accent-text);
}
.selected.featured .tag-count {
    color: var(--app-bg-primary);
}

.tag-trigger.selected .tag-count {
    background: var(--accent-color);
}
.tag-trigger.selected.featured .tag-count {
    background: var(--featured);
}

  .search-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    color: var(--component-text-secondary);
    display: flex;
    align-items: center;
    transition:
      color 0.3s ease,
      transform 0.1s ease,
      background-color 0.3s ease;
    flex-shrink: 0;
    border-radius: 8px;
  }

  .search-btn:not(.active) {
    opacity: 0.7;
    cursor: default;
  }
  .search-btn.active {
    background-color: var(--accent-color);
    color: var(--recommended-accent-text);
  }

  .input-area {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 4px 10px;
    gap: 6px;
    cursor: text;
    min-width: 100px !important;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-size: 1rem;
    padding: 6px 0;
    outline: none;
  }

  .clear-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    color: var(--component-text-secondary);
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    border-radius: 8px;
    opacity: 0.7;
  }

  .clear-btn:hover {
    color: var(--component-text-primary-hover);
    opacity: 1;
  }


  /* Content Area Wrapper */
  .content-wrapper {
    flex: 1;
    min-height: 0;
    margin-bottom: 10vh;
    position: relative;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
  }

  .content-wrapper.visible {
    opacity: 1;
    visibility: visible;
  }

  .content-scroll-area {
    height: 100%;
    overflow-y: auto;
    padding-top: 20px;
    padding-bottom: 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* Blur mask - moved to scroll area */
    mask-image: linear-gradient(
      to bottom,
      transparent,
      black 20px,
      black calc(100% - 20px),
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent,
      black 20px,
      black calc(100% - 20px),
      transparent
    );
  }
  .content-scroll-area::-webkit-scrollbar {
    display: none;
  }

  /* Tag Cloud Overlay */
  .tag-cloud-container {
    background: transparent; /* Removed background */
    border: none; /* Removed border */
    padding: 0; /* Align with content area */
    animation: fadeIn 0.2s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }
  .tags-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center; /* Scattered feel */
    align-content: flex-start;
    flex: 1;
  }
  .tag-cloud-item {
    background: var(--component-bg-blur);
    color: var(--component-text-secondary);
    border: 1px solid var(--border-color);
    padding: 6px 14px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .tag-cloud-item:hover {
    background: var(--component-bg-hover);
    color: var(--component-text-primary-hover);
  }
  .tag-cloud-item.selected {
    background: var(--accent-color);
    color: var(--recommended-accent-text);
    border-color: var(--component-bg-accent);
  }
  .tag-cloud-item.featured {
    color: var(--featured);
    font-weight: 500;
    font-variation-settings: 'wght' 500;
  }

  .tag-cloud-item.featured:hover {
    background: var(--featured-bg);
    color: var(--featured);
    border-color: var(--featured);
  }

  .tag-cloud-item.featured.selected {
    background: var(--featured);
    border-color: var(--featured);
    color: var(--app-bg-primary);
  }

  .tag-count {
    font-size: 0.75em;
    opacity: 0.7;
    background: transparent;
    padding: 0;
    border-radius: 4px;
    min-width: 14px;
    text-align: center;
  }

  .cloud-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 2rem;
    padding-bottom: 1rem;
  }
  .close-cloud-btn {
    background: var(--accent-color);
    color: var(--recommended-accent-text);
    border: none;
    padding: 8px 24px;
    border-radius: 4px;
    margin-bottom: 20px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .close-cloud-btn:hover {
    background: var(--component-bg-accent-hover);
  }

  /* Results */
  .results-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 30px;
  }
  .result-card {
    background: var(--component-bg-blur-alt);
    border: 1px solid var(--border-color);
    padding: 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .result-card:hover {
    background: var(--component-bg-hover);
    border-color: var(--component-text-primary-hover);
  }
  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }
  .post-title {
    margin: 0;
    font-size: 1.2rem;
    color: var(--text-primary);
  }
  .post-date {
    font-size: 0.9rem;
    color: var(--component-text-secondary);
  }
  .post-tags {
    margin-bottom: 8px;
  }
  .tag-display {
    color: var(--accent-color);
    font-size: 0.85rem;
    margin-right: 10px;
  }
  .tag-display.featured {
    color: var(--featured);
  }
  .post-summary {
    color: var(--component-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .icon {
    width: 24px;
    height: 24px;
    display: block;
  }
  .icon-sm {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Ensure small icons are sized correctly */
  }
  .icon-sm :deep(svg) {
    width: 16px;
    height: 16px;
  }

  .results-container {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    padding: 0;
    flex-shrink: 0;
  }

  .selected-tags-header {
    display: flex;
    flex-direction: row;
    gap: 12px;
    margin-bottom: 0;
    padding: 0;
    flex-shrink: 0;
  }

  .selected-tags-header h3 {
    margin: 0;
    font-size: 1.05rem;
    color: var(--component-text-secondary);
    font-weight: 500;
    font-variation-settings: 'wght' 500;
  }

  .selected-tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .selected-tag-chip {
    display: inline-flex;
    align-items: center;
    background: var(--component-bg-accent-blur);
    color: var(--accent-color);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .selected-tag-chip.featured {
    background: var(--featured-bg);
    color: var(--featured);
    font-weight: 600;
    font-variation-settings: 'wght' 600;
  }
  .chip-remove {
    background: transparent;
    border: none;
    color: var(--component-text-primary-hover);
    cursor: pointer;
    padding: 0;
    margin-left: 6px;
    display: flex;
    align-items: center;
    opacity: 0.7;
  }
  .chip-remove.featured {
    color: var(--featured);
  }
  .chip-remove:hover {
    opacity: 1;
  }

  .results-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--component-text-secondary);
    font-weight: 500;
    font-variation-settings: 'wght' 500;
  }

  .results-count {
    font-size: 1rem;
    color: var(--component-text-primary);
    background: transparent;
    padding: 2px 6px;
    border-radius: 8px;
    border: none;
  }

  .empty,
  .loading {
    text-align: center;
    color: var(--component-text-secondary);
    padding: 2rem;
  }

  .list-spacer {
    height: 40px;
    width: 100%;
    flex-shrink: 0;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script id="chronicle-search-index" type="application/json">
  {JSON.stringify(searchIndex)}
</script>

<script
  define:vars={{
    initialTitle,
    initialTagsJSON: JSON.stringify(initialTags),
    searchIndexJSON: JSON.stringify(searchIndex),
    isLocalMode,
    locale,
    routePrefix,
    featuredLabel: t("tag.featured"),
    resultsTitleText,
    resultsCountText,
  }}
  data-astro-rerun
>
  // 使用原生导航替代astro:transitions/client
  function esc(s) { return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
  function navigateTo(url) {
    window.location.href = url;
  }

  // Check if we are on the search page
  const page = document.getElementById("search-page");
  if (page) {
    // 国际化支持 - 使用服务器端传递的语言设置
    const serverLocale = locale;
    const isChinese = serverLocale === 'zh-CN';
    
    const t = (key, params = {}) => {
      const translations = {
        "search.tagsCount": (p) => {
          if (p && p.count > 1) {
            return isChinese ? `等${p.count}个标签` : ` and ${p.count} more tags`;
          }
          return '';
        },
        "search.resultDescription": (p) => {
          return isChinese ? `${p.searchDescription} 的搜索结果` : `Search results for ${p.searchDescription}`;
        },
        "search.allPosts": () => isChinese ? "所有内容" : "All content",
        "search.items": (p) => {
          return isChinese ? `${p.count} 条` : `${p.count} items`;
        },
        "search.resultsTitle": () => isChinese ? "搜索结果" : "Search results",
        "search.resultsCount": (p) => {
          return isChinese ? `${p.count} 条` : `${p.count} items`;
        }
      };
      
      if (translations[key]) {
        return typeof translations[key] === 'function' ? translations[key](params) : translations[key];
      }
      return key;
    };
    
    const parsedInitialTags = JSON.parse(initialTagsJSON);

    // State
    let searchQuery = initialTitle;
    let selectedTags = [...parsedInitialTags];
    let isTagCloudOpen = false;
    let isSearching = false;

    // DOM elements
    const tagTrigger = document.getElementById("tag-trigger");
    const tagCloud = document.getElementById("tag-cloud");
    const resultsContent = document.getElementById("results-content");
    const resultsContainer = document.getElementById("results-container");
    const contentWrapper = document.getElementById("content-wrapper");
    const selectedTagsEl = document.getElementById("selected-tags");
    const searchBoxRoot = document.querySelector(
      '[data-searchbox-id="search-page-searchbox"]',
    );

    function syncSearchBoxValue(value) {
      const searchInput = searchBoxRoot?.querySelector("#search-input");
      if (!searchInput) return;

      searchInput.value = value;
      searchInput.dispatchEvent(new Event("input", { bubbles: true }));
    }

    // 清除URL参数并触发搜索
    function initSearchFromURL() {
      const urlParams = new URLSearchParams(window.location.search);
      const keyword = urlParams.get("keyword") || "";
      const tags = urlParams.get("tags") || "";
      const view = urlParams.get("view") || "";

      // Tag cloud view: directly open tag cloud, then clean URL
      if (view === "tags") {
        isTagCloudOpen = true;
        syncTagTriggerState();
        updateCenteredMode();
        updateVisibility();
        const cleanUrl = window.location.pathname;
        window.history.replaceState({}, '', cleanUrl);
        return;
      }

      if (keyword || tags) {
        // 更新搜索状态
        if (keyword) {
          searchQuery = keyword;
          syncSearchBoxValue(keyword);
        }
        
        if (tags) {
          const tagList = tags.split(",").filter(t => t.trim());
          selectedTags = [...new Set([...selectedTags, ...tagList])];
          
          // 更新标签选择状态
          tagList.forEach(tag => {
            const tagElement = document.querySelector(`.tag-cloud-item[data-tag="${tag}"]`);
            if (tagElement) {
              tagElement.classList.add("selected");
            }
          });
          
          renderTagChips();
        }
        
        // 更新搜索框控件状态
        syncTagTriggerState();
        updateCenteredMode();
        updateVisibility();
        
        // 立即触发搜索
        setTimeout(() => {
          performSearch();
          
          // 清除URL参数（不刷新页面）
          const newUrl = window.location.pathname;
          window.history.replaceState({}, document.title, newUrl);
        }, 100);
      }
    }

    function sortTagsList(tags) {
      if (!tags || !Array.isArray(tags)) return [];
      return [...tags].sort((a, b) => {
        if (a === "featured" || a === "精选") return -1;
        if (b === "featured" || b === "精选") return 1;
        return a.localeCompare(b);
      });
    }

    function isAnyTagsSelected(){
      return selectedTags.length > 0;
    }

    function isFeaturedTagSelected() {
      return selectedTags.includes("featured") || selectedTags.includes("精选");
    }

    function isSearchActive() {
      return searchQuery.trim().length > 0 || isAnyTagsSelected();
    }

    function updateCenteredMode() {
      if (page) {
        page.classList.toggle(
          "centered-mode",
          !isSearchActive() && !isTagCloudOpen,
        );
      }
    }

    function updateVisibility() {
      const shouldShow = isSearchActive() || isTagCloudOpen;

      if (shouldShow) {
        if (contentWrapper) {
          contentWrapper.style.display = "block";
          void contentWrapper.offsetHeight; // force reflow
          contentWrapper.classList.add("visible");
        }
        if (isTagCloudOpen) {
          if (tagCloud) {
            tagCloud.style.display = "flex";
            tagCloud.style.zIndex = "10";
          }
          if (resultsContent) {
            resultsContainer.style.display = "none";
            resultsContainer.style.zIndex = "1";
          }
        } else {
          if (tagCloud) {
            tagCloud.style.display = "none";
            tagCloud.style.zIndex = "1";
          }
          if (resultsContent) {
            resultsContainer.style.display = "flex";
            resultsContainer.style.zIndex = "10";
          }
        }
      } else {
        if (contentWrapper) {
          contentWrapper.classList.remove("visible");
          setTimeout(() => {
            if (!isSearchActive() && !isTagCloudOpen) {
              contentWrapper.style.display = "none";
              if (tagCloud) tagCloud.style.display = "none";
              if (resultsContent) resultsContainer.style.display = "none";
            }
          }, 400); // match transition
        }
      }
    }

    function renderTagChips() {
      const selectedTagsHeader = document.getElementById(
        "selected-tags-header",
      );
      const selectedTagsList = document.getElementById("selected-tags-list");

      if (!selectedTagsList) return;

      if (selectedTags.length > 0) {
        if (selectedTagsHeader) selectedTagsHeader.style.display = "flex";

        selectedTagsList.innerHTML = sortTagsList(selectedTags)
          .map((tag) => {
            const isF = tag === "featured" || tag === "精选";
            return `
            <span class="selected-tag-chip ${isF ? "featured" : ""}">
              #${esc(isF ? featuredLabel : tag)}
              <button class="chip-remove ${isF ? "featured" : ""}" data-tag="${esc(tag)}" title="移除标签">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </span>
          `;
          })
          .join("");

        // 添加移除按钮事件
        selectedTagsList.querySelectorAll(".chip-remove").forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const tag = btn.getAttribute("data-tag");
            selectedTags = selectedTags.filter((t) => t !== tag);
            const cloudItem = document.querySelector(
              `.tag-cloud-item[data-tag="${tag}"]`,
            );
            if (cloudItem) cloudItem.classList.remove("selected");
            syncTagTriggerState();
            renderTagChips();
            filterPosts();
            updateCenteredMode();
            updateVisibility();
          });
        });
      } else {
        if (selectedTagsHeader) selectedTagsHeader.style.display = "none";
        selectedTagsList.innerHTML = "";
      }
    }

    function syncTagTriggerState() {
      if (tagTrigger) {
        tagTrigger.classList.toggle(
          "active",
          selectedTags.length > 0 || isTagCloudOpen,
        );
        
        // 更新selected和featured类
        tagTrigger.classList.toggle("selected", selectedTags.length > 0);
        const hasFeatured = selectedTags.some(tag => tag === "featured" || tag === "精选");
        tagTrigger.classList.toggle("featured", hasFeatured);
        
        // 更新标签数量显示
        const tagCountEl = tagTrigger.querySelector(".tag-count");
        if (selectedTags.length > 0) {
          if (!tagCountEl) {
            const countEl = document.createElement("span");
            countEl.className = "tag-count";
            countEl.textContent = selectedTags.length;
            tagTrigger.appendChild(countEl);
          } else {
            tagCountEl.textContent = selectedTags.length;
          }
        } else {
          if (tagCountEl) {
            tagCountEl.remove();
          }
        }
      }

      searchBoxRoot?.dispatchEvent(
        new CustomEvent("searchbox:selection-change", {
          detail: {
            selectedTagsCount: selectedTags.length,
          },
        }),
      );
    }

    function buildSearchUrl(keyword, tags = []) {
      const searchParams = new URLSearchParams();
      if (String(keyword || '').trim()) {
        searchParams.set('keyword', String(keyword || '').trim());
      }
      if (tags.length > 0) {
        searchParams.set('tags', tags.join(','));
      }
      searchParams.set('t', String(Date.now()));
      return `/api/search?${searchParams.toString()}`;
    }

    // Local search index — populated from embedded data when isLocalMode
    const localSearchIndex = isLocalMode ? JSON.parse(searchIndexJSON) : [];

    function localSearch(keyword, tags = []) {
      let results = localSearchIndex;
      const kw = String(keyword || '').trim().toLowerCase();

      if (kw) {
        results = results.filter((p) => {
          if ((p.title || '').toLowerCase().includes(kw)) return true;
          if ((p.summary || '').toLowerCase().includes(kw)) return true;
          if ((p.tags || []).some((t) => String(t).toLowerCase().includes(kw))) return true;
          return false;
        });
      }

      if (tags && tags.length > 0) {
        results = results.filter((p) =>
          tags.every((t) => (p.tags || []).map((x) => String(x).trim()).includes(t))
        );
      }

      results.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
      return results;
    }

    async function fetchSearchResults(keyword, tags = []) {
      if (isLocalMode) {
        return localSearch(keyword, tags);
      }
      const searchUrl = buildSearchUrl(keyword, tags);
      const res = await fetch(searchUrl, { cache: "no-store" });
      if (!res.ok) {
        throw new Error(`Search request failed: ${res.status}`);
      }
      const json = await res.json();
      // Unwrap { code, data, message } API response format
      const data = (json && json.data) ?? json;
      return Array.isArray(data) ? data : [];
    }

    async function filterPosts() {
      if (!resultsContent) return;
      const query = searchQuery.trim();

      // Avoid rendering full list when search is inactive (empty query + no tags)
      if (!query && selectedTags.length === 0) {
        resultsContent.innerHTML = "";
        const loadingState = document.getElementById("loading-state");
        if (loadingState) loadingState.style.display = "none";
        const emptyState = document.getElementById("empty-state");
        if (emptyState) emptyState.style.display = "none";
        return;
      }

      // 显示加载状态
      const loadingState = document.getElementById("loading-state");
      if (loadingState) loadingState.style.display = "block";

      try {
        const filtered = await fetchSearchResults(query, selectedTags);

        if (loadingState) loadingState.style.display = "none";

        // 更新结果头部
        const resultsHeader = document.getElementById("results-header");
        const resultsTitle = document.getElementById("results-title");
        const resultsCount = document.getElementById("results-count");

        if (filtered.length === 0) {
          resultsContent.innerHTML = "";
          const emptyState = document.getElementById("empty-state");
          if (emptyState) emptyState.style.display = "block";
          if (resultsHeader) resultsHeader.style.display = "none";
        } else {
          const emptyState = document.getElementById("empty-state");
          if (emptyState) emptyState.style.display = "none";

          // 显示结果头部
          if (resultsHeader) resultsHeader.style.display = "flex";

          // 更新结果标题和数量
          if (resultsTitle && resultsCount) {
            // 构建搜索条件描述
            let searchDescription = "";

            if (searchQuery.trim()) {
              searchDescription += `"${searchQuery.trim()}"`;
            }

            if (selectedTags.length > 0) {
              if (searchQuery.trim()) {
                searchDescription += " + ";
              }

              if (selectedTags.length === 1) {
                searchDescription += `"${selectedTags[0]}"`;
              } else {
                searchDescription += `"${selectedTags[0]}"${t("search.tagsCount", { count: selectedTags.length })}`;
              }
            }

            // 如果没有搜索条件，显示默认描述
            if (!searchDescription) {
              searchDescription = t("search.allPosts");
            }

            resultsTitle.textContent = t("search.resultDescription", {
              searchDescription,
            });
            resultsCount.textContent = t("search.items",{
              count: filtered.length,
            });
          }

          resultsContent.innerHTML = filtered
            .map((post) => {
              const isF = (tag) => tag === "featured" || tag === "精选";
              return `
              <article class="result-card" data-post-id="${esc(String(post.id))}">
                <div class="post-header">
                  <h3 class="post-title">${esc(post.title)}</h3>
                  <span class="post-date">${new Date(post.date).toLocaleDateString(locale)}</span>
                </div>
                ${
                  post.tags && post.tags.length > 0
                    ? `
                  <div class="post-tags">
                    ${sortTagsList(post.tags)
                      .map(
                        (tag) => `
                      <span class="tag-display ${isF(tag) ? "featured" : ""}">
                        #${esc(isF(tag) ? featuredLabel : tag)}
                      </span>
                    `,
                      )
                      .join("")}
                  </div>
                `
                    : ""
                }
                <div class="post-summary">${esc(post.summary || "")}</div>
              </article>
            `;
            })
            .join("");

          resultsContent.querySelectorAll(".result-card").forEach((card) => {
            card.addEventListener("click", () => {
              const postId = card.getAttribute("data-post-id");
              if (!postId) return;
              navigateTo(`${routePrefix}/post/${postId}`);
            });
          });
        }
      } catch (error) {
        console.error("[Search] Error filtering posts:", error);
        const loadingState = document.getElementById("loading-state");
        if (loadingState) loadingState.style.display = "none";
        const emptyState = document.getElementById("empty-state");
        if (emptyState) emptyState.style.display = "block";
        resultsContent.innerHTML = "";
      }
    }

    function toggleTagCloud() {
      isTagCloudOpen = !isTagCloudOpen;

      syncTagTriggerState();
      updateCenteredMode();
      updateVisibility();
    }

    async function performSearch() {
      // 检查搜索按钮是否激活
      const isActive = searchQuery.trim() || isAnyTagsSelected();
      if (!isActive || isSearching) {
        if (!isActive) {
          isTagCloudOpen = false;
          updateCenteredMode();
          updateVisibility();
        }
        return;
      }

      isSearching = true;

      // 关闭词云图
      isTagCloudOpen = false;

      // 更新界面状态
      updateCenteredMode();
      updateVisibility();

      // 执行搜索
      await filterPosts();

      // 更新页面标题
      if (searchQuery.trim()) {
        document.title = `Search: ${searchQuery} - Chronicle`;
      } else {
        document.title = "Search - Chronicle";
      }

      isSearching = false;
    }

    searchBoxRoot?.addEventListener("searchbox:submit", (event) => {
      const detail = event.detail || {};
      searchQuery = String(detail.query || "");
      syncTagTriggerState();
      performSearch();
    });

    searchBoxRoot?.addEventListener("searchbox:clear", () => {
      searchQuery = "";
      selectedTags = [];

      document.querySelectorAll(".tag-cloud-item.selected").forEach((item) => {
        item.classList.remove("selected");
      });

      syncTagTriggerState();
      renderTagChips();
      updateCenteredMode();
      updateVisibility();
      filterPosts();
    });

    searchBoxRoot?.addEventListener("searchbox:toggle-tag-cloud", () => {
      toggleTagCloud();
    });

    document.querySelectorAll(".tag-cloud-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.getAttribute("data-tag");
        if (selectedTags.includes(tag)) {
          selectedTags = selectedTags.filter((t) => t !== tag);
          btn.classList.remove("selected");
        } else {
          selectedTags.push(tag);
          btn.classList.add("selected");
        }
        syncTagTriggerState();
        renderTagChips();
        // 标签选择后不自动触发搜索，等待用户手动触发
      });
    });

    // Initialize
    if (parsedInitialTags.length > 0) {
      renderTagChips();
      parsedInitialTags.forEach((tag) => {
        document
          .querySelector(`.tag-cloud-item[data-tag="${tag}"]`)
          ?.classList.add("selected");
      });
    }

    syncTagTriggerState();

    // Always run initial filter to correctly display the initial state
    filterPosts();
    updateCenteredMode();
    updateVisibility();

    // 延迟检查URL参数并自动触发搜索（确保所有DOM元素已加载）
    setTimeout(() => {
      initSearchFromURL();
    }, 100);

    if (initialTitle || parsedInitialTags.length > 0) {
      window.history.replaceState({}, "", `${routePrefix}/search`);
    }

    // 智能预加载其他页面
    import("../../utils/preload.ts")
      .then(({ executeSmartPreload }) => {
        // 延迟执行预加载，避免影响首屏性能
        setTimeout(() => {
          executeSmartPreload();
        }, 2000);
      })
      .catch((err) => {
        console.warn("[Preload] Failed to load preload module:", err);
      });
  }
</script>