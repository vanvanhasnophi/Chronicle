---
const props = (Astro.props || {}) as {
  instanceId?: string;
  searchSuggestionsEnabled?: boolean;
  showTagTrigger?: boolean;
  initialTitle?: string;
  featuredLabel?: string;
  routePrefix?: string;
  t?: (k: string) => string;
  searchOnEnter?: boolean;
  searchBtnAsButton?: boolean;
};

const searchSuggestionsEnabled = props.searchSuggestionsEnabled ?? false;
const showTagTrigger = props.showTagTrigger ?? props.searchSuggestionsEnabled ?? false;
const instanceId = props.instanceId ?? 'searchbox';
const initialTitle = props.initialTitle ?? '';
const featuredLabel = props.featuredLabel ?? '';
const routePrefix = props.routePrefix ?? '/';
const t = props.t ?? ((k: string) => k);
const searchOnEnter = props.searchOnEnter ?? true;
const searchBtnAsButton = props.searchBtnAsButton ?? true;
---

<div class="search-box-wrapper" data-searchbox-id={instanceId}>
  <div class="search-box">
    {showTagTrigger && (
      <>
        <button
          class="tag-trigger"
          id="tag-trigger"
          title={t("search.selectTags")}
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="4" y1="9" x2="20" y2="9"></line>
            <line x1="4" y1="15" x2="20" y2="15"></line>
            <line x1="10" y1="3" x2="8" y2="21"></line>
            <line x1="16" y1="3" x2="14" y2="21"></line>
          </svg>
        </button>
        <span class="divider"></span>
      </>
    )}

    <div class="input-area" id="input-area">
      <input
        id="search-input"
        type="text"
        placeholder={t("search.placeholder")}
        class="search-input"
        value={initialTitle}
      />
    </div>

    <button class="clear-btn" id="clear-btn" title="清空搜索" style="display:none;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    {searchBtnAsButton ? (
      <button class="search-btn" id="search-btn" type="button" title={t("search.search")} data-search-btn="true" disabled={initialTitle.trim().length === 0}>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      </button>
    ) : (
      <div class="search-btn search-btn--static" id="search-btn" title={t("search.search")} aria-hidden="true" aria-disabled="true">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </div>
    )}
  </div>
</div>

<script
  define:vars={{ instanceId, initialTitle, searchOnEnter, searchBtnAsButton, showTagTrigger }}
>
  function initSearchBox() {
    // Re-query DOM on each init (handles view-transition swaps)
    const root = document.querySelector(`[data-searchbox-id="${instanceId}"]`);
    if (!root || root.dataset.searchboxInit === '1') return;
    root.dataset.searchboxInit = '1';

    const input = root.querySelector('#search-input');
    const searchBtn = root.querySelector('#search-btn');
    const clearBtn = root.querySelector('#clear-btn');
    const tagTrigger = root.querySelector('#tag-trigger');

    let selectedTagsCount = 0;

    const submitEventName = 'searchbox:submit';
    const toggleTagCloudEventName = 'searchbox:toggle-tag-cloud';

    function emit(name, detail) {
      (root || document).dispatchEvent(new CustomEvent(name, {
        bubbles: true,
        detail,
      }));
    }

    function updateState() {
      if (!input || !searchBtn || !clearBtn) return;
      const hasContent = input.value.trim().length > 0;
      const isActive = hasContent || selectedTagsCount > 0;
      searchBtn.classList.toggle('active', isActive);
      if ('disabled' in searchBtn) {
        searchBtn.disabled = !isActive;
      }
      clearBtn.classList.toggle('active', isActive);
      clearBtn.style.display = isActive ? 'flex' : 'none';
    }

    function submitSearch(source) {
      const hasContent = input ? input.value.trim().length > 0 : false;
      const isActive = hasContent || selectedTagsCount > 0;
      if (!isActive) return;
      emit(submitEventName, {
        query: input ? input.value.trim() : '',
        source,
      });
    }

    if (input) {
      input.value = initialTitle || input.value || '';
      updateState();

      input.addEventListener('input', updateState);
      if (searchOnEnter) {
        input.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            const hasContent = input.value.trim().length > 0;
            const isActive = hasContent || selectedTagsCount > 0;
            if (!isActive) {
              event.preventDefault();
              return;
            }
            event.preventDefault();
            submitSearch('enter');
          }
        });
      }
    }

    if (searchBtnAsButton && searchBtn) {
      searchBtn.addEventListener('click', () => submitSearch('button'));
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        if (input) {
          input.value = '';
        }
        updateState();
        emit('searchbox:clear', {});
        input?.focus();
      });
    }

    if (showTagTrigger && tagTrigger) {
      tagTrigger.addEventListener('click', () => {
        emit(toggleTagCloudEventName, {});
      });
    }

    root.addEventListener('searchbox:selection-change', (event) => {
      const detail = event.detail || {};
      selectedTagsCount = Number(detail.selectedTagsCount || 0);
      updateState();
    });
  }

  // Init on load
  initSearchBox();
  // Re-init after Astro view transitions swap in new DOM
  document.addEventListener('astro:after-swap', initSearchBox);
</script>

<style>
  .search-box-wrapper {
    flex-shrink: 0;
    margin-bottom: 2rem;
    z-index: 50;
    width: 100%;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--component-bg-blur-alt);
    border: 1px solid var(--border-color-blur);
    border-radius: 12px;
    padding: 4px;
    transition: box-shadow 0.3s ease;
    box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.05);
  }
  .search-box:focus-within {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 2px var(--component-bg-accent-blur);
  }

  .divider {
    width: 1px;
    height: 28px;
    background-color: var(--border-color-blur);
    margin: 0 2px;
  }

  .tag-trigger {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    color: var(--component-text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.3s ease, transform 0.1s ease, background-color 0.3s ease;
    flex-shrink: 0;
    border-radius: 8px;
    position: relative;
  }
  .tag-trigger.active:not(.featured) {
    color: var(--accent-color);
  }

  .tag-trigger.selected {
    background: var(--component-bg-accent-blur);
    color: var(--accent-color);
  }

  .tag-trigger.selected.featured {
    background: var(--featured-bg);
    color: var(--featured);
  }

  .tag-trigger.selected:hover {
    filter: brightness(1.1);
  }
  .tag-trigger.selected.featured:hover {
    filter: brightness(1.1);
  }

  .tag-trigger:not(.featured):hover {
    color: var(--accent-color);
  }

  .tag-count {
    background: var(--app-bg-primary);
    color: var(--component-text-secondary);
    font-size: 0.75rem;
    font-weight: 500;
    font-variation-settings: 'wght' 500;
    padding: 2px 6px;
    border-radius: 10px;
    min-width: 16px;
    text-align: center;
    line-height: 1;
    align-content: center;
  }

  .tag-trigger .tag-count{
    width:16px;
    height:16px;
  }

  .search-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    color: var(--component-text-secondary);
    display: flex;
    align-items: center;
    transition:
      color 0.3s ease,
      transform 0.1s ease,
      background-color 0.3s ease;
    flex-shrink: 0;
    border-radius: 8px;
  }

  .search-btn--static {
    cursor: default;
    pointer-events: none;
    opacity: 0.7;
  }

  .search-btn:not(.active) {
    opacity: 0.7;
    cursor: default;
  }
  .search-btn.active {
    background-color: var(--accent-color);
    color: var(--recommended-accent-text);
  }

  .input-area {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 4px 10px;
    gap: 6px;
    cursor: text;
    min-width: 100px !important;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-size: 1rem;
    padding: 6px 0;
    outline: none;
  }

  .clear-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    color: var(--component-text-secondary);
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    border-radius: 8px;
    opacity: 0.7;
  }

  .clear-btn:hover {
    color: var(--component-text-primary-hover);
    opacity: 1;
  }
</style>
