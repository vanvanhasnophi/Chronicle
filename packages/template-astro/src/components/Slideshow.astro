---
// Chronicle Slideshow — Marp-based slide rendering at SSG build time.
// Reads post content directly from data source (no base64 encoding needed).

import { getPostById } from '../data/localDataSource'
import { chronicleCSS, chronicleDarkCSSStr } from '@chronicle/shared/src/styles/chronicle-marp-theme'
import marpCore from '@marp-team/marp-core'

interface Props {
  id: string
  config?: { theme?: string; ratio?: string; footer?: string }
}

const { id, config = {} } = Astro.props as Props
const post = getPostById(id)
const md = post?.content || ''
const ratio = config.ratio || '16:9'

let slideHTML = ''; let slideCSS = ''; let totalSlides = 0

if (md.trim()) {
  const Marp = (marpCore as any).default || marpCore
  const marp = new Marp({ html: true })

  // Register Chronicle themes (must be done before render)
  try { marp.themeSet.add(chronicleCSS) } catch (e) { console.error('[Slideshow] Failed to register chronicle theme:', e) }
  try { marp.themeSet.add(chronicleDarkCSSStr) } catch (e) { console.error('[Slideshow] Failed to register chronicle-dark theme:', e) }

  try {
    const r = marp.render(md)
    slideHTML = r.html; slideCSS = r.css
    totalSlides = (slideHTML.match(/<\/section>/g) || []).length
  } catch (e) {
    console.error('[Slideshow] marp.render failed:', e)
    slideHTML = `<section><pre>${md.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</pre></section>`
  }
}
---

<div class="chronicle-slideshow" id="chronicle-slideshow" data-total={totalSlides}>
  <style set:html={slideCSS} />
  <div class="slides-container">
    <div class="slides-viewport" id="slides-viewport">
      <div class="marp-slides-wrap marp-slides-browse" id="marp-slides-browse"><div class="marp-slides" set:html={slideHTML} /></div>
      <div class="marp-slides-wrap marp-slides-present" id="marp-slides-present" style="display:none"><div class="marp-slides" set:html={slideHTML} /></div>
    </div>
    <div class="slides-controls no-print">
      <a href="../" class="slide-back-link" title="Back to blogs">✕</a>
      <button id="slide-prev" title="Previous (←)">←</button>
      <span class="slide-counter" id="slide-counter">1 / {totalSlides}</span>
      <button id="slide-next" title="Next (→)">→</button>
      <span class="slide-view-spacer"></span>
      <span class="slide-zoom-group" id="slide-zoom-group">
        <button id="slide-zoom-out" title="Zoom out (Ctrl+scroll)">−</button>
        <span class="slide-zoom-label" id="slide-zoom-label">100%</span>
        <button id="slide-zoom-in" title="Zoom in (Ctrl+scroll)">+</button>
        <button id="slide-zoom-reset" title="Reset zoom">1:1</button>
      </span>
      <button id="slide-view-browse" class="active" title="Browse all slides">📜 Browse</button>
      <button id="slide-view-present" title="Present one slide">📄 Present</button>
    </div>
  </div>
</div>

<script>
  const el = document.getElementById('chronicle-slideshow')
  if (!el) throw new Error('Slideshow container not found')
  const browseBox = document.getElementById('marp-slides-browse')!
  const presentBox = document.getElementById('marp-slides-present')!
  const browseSlides = browseBox.querySelector('.marp-slides')!
  const total = parseInt(el.dataset.total || '0')
  let current = 0
  let viewMode: 'present' | 'browse' = 'browse'

  function updateView() {
    const isPresent = viewMode === 'present'
    // Set html.focus FIRST so CSS display:flex is active before clearing inline display:none
    document.documentElement.classList.toggle('focus', isPresent)
    browseBox.style.display = isPresent ? 'none' : ''
    presentBox.style.display = isPresent ? '' : 'none'
    if (isPresent) {
      const svgs = presentBox.querySelectorAll('[data-marpit-svg]')
      svgs.forEach((s: any, i: number) => { s.style.display = i === current ? '' : 'none' })
    }
    document.getElementById('slide-view-present')?.classList.toggle('active', isPresent)
    document.getElementById('slide-view-browse')?.classList.toggle('active', !isPresent)
    document.getElementById('slide-counter')!.textContent = `${current + 1} / ${total}`
    updateZoomUI()
  }

  function next() { if (current < total - 1) { current++; updateView() } }
  function prev() { if (current > 0) { current--; updateView() } }

  document.addEventListener('keydown', (e) => {
    if ((e.target as HTMLElement)?.closest('input,textarea')) return
    switch (e.key) {
      case 'ArrowRight': case 'PageDown': case ' ': e.preventDefault(); next(); break
      case 'ArrowLeft': case 'PageUp': e.preventDefault(); prev(); break
      case 'Home': e.preventDefault(); current = 0; updateView(); break
      case 'End': e.preventDefault(); current = total - 1; updateView(); break
    }
  })

  let tx = 0
  document.addEventListener('touchstart', e => { tx = e.touches[0].clientX })
  document.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - tx
    if (Math.abs(dx) > 50) dx > 0 ? prev() : next()
  })

  document.getElementById('slide-prev')?.addEventListener('click', prev)
  document.getElementById('slide-next')?.addEventListener('click', next)
  document.getElementById('slide-view-present')?.addEventListener('click', () => { browseZoom = zoom; viewMode = 'present'; updateView() })
  document.getElementById('slide-view-browse')?.addEventListener('click', () => { viewMode = 'browse'; updateView() })

  // ── Zoom (Browse only) ──
  const zoomLabel = document.getElementById('slide-zoom-label')!
  const zoomGroup = document.getElementById('slide-zoom-group')!
  let browseZoom = 1
  let zoom = 1
  const ZOOM_MIN = 0.25; const ZOOM_MAX = 4; const ZOOM_STEP = 0.1
  function setZoom(z: number) {
    zoom = Math.min(ZOOM_MAX, Math.max(ZOOM_MIN, z))
    browseSlides.style.setProperty('--slide-zoom', String(zoom))
    zoomLabel.textContent = Math.round(zoom * 100) + '%'
  }
  document.addEventListener('wheel', (e) => {
    if (viewMode !== 'browse' || !e.ctrlKey) return
    e.preventDefault()
    setZoom(zoom - Math.sign(e.deltaY) * ZOOM_STEP)
  }, { passive: false })
  document.getElementById('slide-zoom-out')?.addEventListener('click', () => setZoom(zoom - ZOOM_STEP))
  document.getElementById('slide-zoom-in')?.addEventListener('click', () => setZoom(zoom + ZOOM_STEP))
  document.getElementById('slide-zoom-reset')?.addEventListener('click', () => setZoom(1))
  function updateZoomUI() { zoomGroup.style.display = viewMode === 'browse' ? '' : 'none' }
  updateZoomUI()

  const h = parseInt(location.hash.slice(1))
  if (h >= 1 && h <= total) current = h - 1
  const saved = localStorage.getItem('chronicle-slides-view')
  if (saved === 'present') viewMode = 'present'
  updateView()
</script>

<style is:global>
  @import '@chronicle/shared/src/styles/chronicle-slides.css';
</style>
