---
import Layout from '../../layouts/Layout.astro';
import { getApiUrl } from '../../config/api';

const { id } = Astro.params;

// 获取帖子详情
let post = null;
let error = null;

try {
  // 通过查询参数获取单个帖子
  const response = await fetch(getApiUrl(`/api/posts?id=${id}`, true));
  if (response.ok) {
    const data = await response.json();
    // 检查返回的数据结构
    if (Array.isArray(data) && data.length > 0) {
      post = data[0];
    } else if (data.posts && Array.isArray(data.posts) && data.posts.length > 0) {
      post = data.posts[0];
    } else {
      error = '帖子不存在';
    }
  } else {
    error = `帖子不存在 (${response.status})`;
  }
} catch (err) {
  error = '获取帖子详情失败';
  console.error('Error fetching post:', err);
}

// 如果没有找到帖子，显示404
if (!post && !error) {
  error = '帖子不存在';
}

// 设置页面标题
if (post) {
  Astro.props.title = `${post.title} - Chronicle`;
} else {
  Astro.props.title = '帖子不存在 - Chronicle';
}
---

<Layout title={Astro.props.title}>
  <div class="post-detail-container">
    {error ? (
      <div class="error-container">
        <h1>帖子不存在</h1>
        <p>{error}</p>
        <a href="/blogs" class="back-link">← 返回博客列表</a>
      </div>
    ) : post ? (
      <article class="post-content">
        <!-- 导航栏 -->
        <nav class="post-nav">
          <a href="/blogs" class="nav-back">← 返回博客列表</a>
        </nav>

        <!-- 帖子头部 -->
        <header class="post-header">
          <h1 class="post-title">{post.title}</h1>
          
          <div class="post-meta">
            <div class="meta-row">
              <span class="meta-item">创建时间: {new Date(post.date).toLocaleDateString('zh-CN')}</span>
              {post.updatedAt && post.updatedAt !== post.date && (
                <span class="meta-item">更新时间: {new Date(post.updatedAt).toLocaleDateString('zh-CN')}</span>
              )}
            </div>
            
            {post.tags && post.tags.length > 0 && (
              <div class="post-tags">
                {post.tags.map((tag: string) => (
                  <span class="tag" class:list={[{ featured: tag === 'featured' || tag === '精选' }]}>
                    {tag === 'featured' || tag === '精选' ? '精选' : tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </header>

        <!-- 帖子内容 -->
        <div class="post-body">
          <div class="markdown-content" set:html={post.content} />
        </div>

        <!-- 底部导航 -->
        <footer class="post-footer">
          <a href="/blogs" class="back-link">← 返回博客列表</a>
        </footer>
      </article>
    ) : null}
  </div>

  <style is:global>
    .post-detail-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .error-container {
      text-align: center;
      padding: 4rem 1rem;
    }

    .error-container h1 {
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .post-nav {
      margin-bottom: 2rem;
    }

    .nav-back, .back-link {
      color: var(--accent-color);
      text-decoration: none;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .nav-back:hover, .back-link:hover {
      text-decoration: underline;
    }

    .post-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1.5rem;
    }

    .post-title {
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .post-meta {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .meta-row {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .post-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .tag {
      background: var(--component-bg-alt);
      color: var(--text-secondary);
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.8rem;
      border: 1px solid var(--border-color);
    }

    .tag.featured {
      background: var(--accent-color);
      color: white;
      border-color: var(--accent-color);
    }

    .post-body {
      line-height: 1.7;
      font-size: 1.1rem;
    }

    .markdown-content {
      /* Markdown内容样式 */
    }

    .markdown-content h1,
    .markdown-content h2,
    .markdown-content h3,
    .markdown-content h4,
    .markdown-content h5,
    .markdown-content h6 {
      margin: 2rem 0 1rem 0;
      font-weight: 600;
      line-height: 1.3;
    }

    .markdown-content h1 {
      font-size: 2rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .markdown-content h2 {
      font-size: 1.75rem;
    }

    .markdown-content h3 {
      font-size: 1.5rem;
    }

    .markdown-content p {
      margin: 1rem 0;
    }

    .markdown-content ul,
    .markdown-content ol {
      margin: 1rem 0;
      padding-left: 2rem;
    }

    .markdown-content li {
      margin: 0.5rem 0;
    }

    .markdown-content blockquote {
      border-left: 4px solid var(--accent-color);
      margin: 1.5rem 0;
      padding: 0.5rem 1rem;
      background: var(--component-bg-alt);
      border-radius: 0 4px 4px 0;
    }

    .markdown-content code {
      background: var(--component-bg-alt);
      padding: 0.2rem 0.4rem;
      border-radius: 3px;
      font-size: 0.9em;
      font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    }

    .markdown-content pre {
      background: var(--component-bg-alt);
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1.5rem 0;
      border: 1px solid var(--border-color);
    }

    .markdown-content pre code {
      background: none;
      padding: 0;
    }

    .markdown-content a {
      color: var(--accent-color);
      text-decoration: none;
    }

    .markdown-content a:hover {
      text-decoration: underline;
    }

    .markdown-content img {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
      margin: 1rem 0;
    }

    .markdown-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }

    .markdown-content th,
    .markdown-content td {
      border: 1px solid var(--border-color);
      padding: 0.75rem;
      text-align: left;
    }

    .markdown-content th {
      background: var(--component-bg-alt);
      font-weight: 600;
    }

    .post-footer {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
      text-align: center;
    }

    @media (max-width: 768px) {
      .post-detail-container {
        padding: 1rem 0.5rem;
      }

      .post-title {
        font-size: 2rem;
      }

      .meta-row {
        flex-direction: column;
        gap: 0.5rem;
      }
    }
  </style>
</Layout>