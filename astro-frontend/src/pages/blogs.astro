---
import Layout from "../layouts/Layout.astro";
import BackToTop from "../components/BackToTop.astro";
import { getTranslation, getLocale } from "../utils/i18n";
import { API_BASE_URL, getApiUrl } from "../config/api";
import { initPreloadSystem } from "../utils/preload";

// Get locale from Astro.locals (set by middleware)
const locale = getLocale(Astro.locals);
const t = (key: string) => getTranslation(locale, key);

// Fetch settings (SSR - uses full URL to backend)
let settings: Record<string, any> = {};
try {
  const res = await fetch(getApiUrl(`/api/settings?t=${Date.now()}`, true), {
    cache: "no-store",
  });
  if (res.ok) settings = await res.json();
} catch (e) {
  console.error("[blogs] Failed to fetch settings:", e);
}

const PAGE_SIZE = 10;
const initialPostsRequestUrl = getApiUrl(
  `/api/posts?page=1&perPage=${PAGE_SIZE}&timeline=desc&t=${Date.now()}`,
  true,
);

let initialPosts: any[] = [];
try {
  const res = await fetch(
    initialPostsRequestUrl,
    {
      cache: "no-store",
    },
  );
  if (res.ok) {
    const data = await res.json();
    initialPosts = Array.isArray(data) ? data : data.posts || [];
  }
} catch (e) {
  console.error("[blogs] Failed to fetch initial posts:", e);
}

let initialFeaturedPosts: any[] = [];
let initialFeaturedTotal: number = 0;
try {
  const featuredUrl = getApiUrl(
    `/api/posts?featured=true&timeline=desc&t=${Date.now()}`,
    true,
  );
  const res = await fetch(featuredUrl, { cache: "no-store" });
  if (res.ok) {
    const data = await res.json();
    initialFeaturedPosts = Array.isArray(data) ? data : data.posts || [];
    initialFeaturedTotal = data.total || initialFeaturedPosts.length;
  }
} catch (e) {
  console.error("[blogs] Failed to fetch featured posts:", e);
}

if (!settings || Object.keys(settings).length === 0) {
  try {
    const res = await fetch(getApiUrl("/api/public/settings?t=" + Date.now(), true), {
      cache: "no-store",
    });
    if (res.ok) settings = await res.json();
  } catch (e) {}
}

const isFeaturedTag = (tag: string) => tag === "featured" || tag === "精选";

const sortTagsList = (tags: unknown) => {
  if (!Array.isArray(tags)) return [];
  return [...tags].sort((a, b) => {
    if (isFeaturedTag(String(a)) && !isFeaturedTag(String(b))) return -1;
    if (!isFeaturedTag(String(a)) && isFeaturedTag(String(b))) return 1;
    return String(a).localeCompare(String(b));
  });
};

const escapeHtml = (value: unknown) =>
  String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");

const formatMonthName = (iso: string) => {
  try {
    return new Date(iso).toLocaleString(locale, { month: "short" });
  } catch (e) {
    return "";
  }
};

const renderFeaturedCard = (post: any, hidden = false) => {
  const date = new Date(post.date);
  const dateText = date.toLocaleDateString(locale);
  const tags = sortTagsList(post.tags);
  const tagHtml = tags.length
    ? `<div class="post-tags">${tags.map((tag) => `<span class="tag${isFeaturedTag(String(tag)) ? " featured" : ""}"># ${isFeaturedTag(String(tag)) ? escapeHtml(t("tag.featured")) : escapeHtml(tag)}</span>`).join("")}</div>`
    : "";

  return `<a href="/post/${encodeURIComponent(post.id)}" style="text-decoration:none; color:inherit;${hidden ? " display:none;" : ""}" class="${hidden ? "hidden-featured" : ""}">
    <article class="post-card featured-card">
      <div class="post-meta"><span class="post-date">${escapeHtml(dateText)}</span></div>
      <h3 class="post-title">${escapeHtml(post.title)}</h3>
      ${tagHtml}
    </article>
  </a>`;
};

const renderArchiveCard = (post: any) => {
  const date = new Date(post.date);
  const dayText = `${date.getDate()}${t("blog.daySuffix")}`;
  const tags = sortTagsList(post.tags);
  const tagHtml = tags.length
    ? `<div class="post-tags">${tags.map((tag) => `<span class="tag${isFeaturedTag(String(tag)) ? " featured" : ""}"># ${isFeaturedTag(String(tag)) ? escapeHtml(t("tag.featured")) : escapeHtml(tag)}</span>`).join("")}</div>`
    : "";

  return `<a href="/post/${encodeURIComponent(post.id)}" style="text-decoration:none; color:inherit;">
    <article class="post-card compact-card">
      <div class="post-header-row">
        <h4 class="post-title">${escapeHtml(post.title)}</h4>
        <span class="post-day">${escapeHtml(dayText)}</span>
      </div>
      ${tagHtml}
    </article>
  </a>`;
};

const buildFeaturedHtml = (posts: any[]) => {
  const featured = [...posts]
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

  return featured
    .slice(0, 3)
    .map((post) => renderFeaturedCard(post, false))
    .join("");
};

const buildArchiveHtml = (posts: any[]) => {
  const sortedPosts = [...posts].sort(
    (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
  );
  const yearMap = new Map<
    number,
    Map<number, { monthName: string; posts: any[] }>
  >();

  sortedPosts.forEach((post) => {
    const date = new Date(post.date);
    const year = date.getFullYear();
    const monthIndex = date.getMonth();
    const monthName = formatMonthName(post.date);
    if (!yearMap.has(year)) yearMap.set(year, new Map());
    const monthMap = yearMap.get(year)!;
    if (!monthMap.has(monthIndex))
      monthMap.set(monthIndex, { monthName, posts: [] });
    monthMap.get(monthIndex)!.posts.push(post);
  });

  return [...yearMap.entries()]
    .sort(([a], [b]) => b - a)
    .map(([year, monthMap]) => {
      const months = [...monthMap.entries()].sort(([a], [b]) => b - a);
      return `<div class="year-block" data-year="${year}">
        <div class="year-header">${year}</div>
        ${months
          .map(
            ([
              monthIndex,
              monthInfo,
            ]) => `<div class="month-row" data-month="${escapeHtml(monthInfo.monthName)}" data-month-index="${monthIndex}">
          <div class="month-label"><span>${escapeHtml(monthInfo.monthName)}</span></div>
          <div class="month-posts">
            ${monthInfo.posts.map((post) => renderArchiveCard(post)).join("")}
          </div>
        </div>`,
          )
          .join("")}
      </div>`;
    })
    .join("");
};

const initialFeaturedHtml = buildFeaturedHtml(initialFeaturedPosts);
const initialArchiveHtml = buildArchiveHtml(initialPosts);
const hasInitialPosts = initialPosts.length > 0;
const hasFeaturedPosts = initialFeaturedPosts.length > 0;
---

<Layout title={t("nav.blogs")} settings={settings}>
  <div class="blog-container">
    <main class="blog-main">
      <!-- Featured Section (client-rendered) -->
      <section
        class="section-block"
        id="featured-section"
        style={`display:${hasFeaturedPosts ? "block" : "none"};`}
      >
        <div class="section-header">
          <h2 class="section-title">{t("blog.featured")}</h2>
          <button
            class="toggle-btn"
            id="featured-toggle"
            style={`display:${initialFeaturedTotal > 3 ? "inline-block" : "none"};`}
              data-expand-text={t("blog.expand")} data-collapse-text={t("blog.collapse")}>{t("blog.expand")}</button
          >
        </div>
        <div
          class="featured-grid"
          id="featured-grid"
          set:html={initialFeaturedHtml}
        />
      </section>

      <!-- Archive Section -->
      <section class="section-block">
        <h2 class="section-title">{t("blog.allPosts")}</h2>

        <div
          class="archive-list"
          id="archive-list"
          set:html={initialArchiveHtml}
        />
        <div
          class="loading initial-loading"
          id="timeline-placeholder"
          style={`display:${hasInitialPosts ? "none" : "flex"};`}
        >
          正在加载文章...
        </div>
        <div
          class="empty"
          id="timeline-empty"
          style={`display:${hasInitialPosts ? "none" : "block"};`}
        >
          {t("blog.noPostsStartWriting")}
        </div>
      </section>
    </main>
  </div>

  <BackToTop />
</Layout>

<style>
  .blog-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px;
    color: var(--text-primary);
    box-sizing: border-box;
    scroll-behavior: smooth;
  }
</style>
<style is:global>
  .section-block {
    margin-bottom: 60px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--accent-color);
    padding-bottom: 10px;
  }

  .section-title {
    font-size: 1.8em;
    margin: 0;
    color: var(--text-primary);
    padding-bottom: 0px;
    border-bottom: none;
    display: inline-block;
  }

  .toggle-btn {
    background: transparent;
    border: none;
    color: var(--component-text-secondary);
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1em;
    transition: all 0.3s;
  }

  .toggle-btn:hover {
    color: var(--component-text-primary-hover);
    border: none;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }

  .featured-card .post-title {
    font-size: 1.1em;
    margin-bottom: 12px;
    white-space: nowrap; /* 1. 强制一行 */
    overflow: hidden; /* 2. 隐藏溢出 */
    text-overflow: ellipsis; /* 3. 显示省略号 */
  }

  .featured-card .post-meta {
    font-size: 0.8em;
  }

  .featured-card .tag {
    font-size: 0.7em;
  }
  .archive-list {
    margin-top: 20px;
  }

  .year-block {
    margin-bottom: 40px;
  }

  .year-header {
    font-size: 3em;
    font-weight: 800 !important;
    font-variation-settings: "wght" 800;
    color: var(--component-text-secondary);
    opacity: 0.3;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border-color);
    line-height: 1;
  }

  .month-row {
    display: flex;
    margin-bottom: 20px;
  }

  .month-label {
    width: 60px;
    flex-shrink: 0;
    text-align: right;
    padding-right: 20px;
    padding-top: 14px;
    font-weight: bold;
    color: var(--accent-color);
    font-size: 1.1em;
  }

  .month-posts {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post-card {
    padding: 16px;
    background: var(--component-bg-blur-alt);
    border: 1px solid var(--border-color-blur);
    border-radius: 8px;
    cursor: pointer;
    transition:
      transform 0.2s,
      border-color 0.2s;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--component-text-primary-hover);
  }

  .compact-card {
    padding: 14px 16px;
    margin-bottom: 0;
    border: 1px solid var(--border-color-blur);
    background: var(--component-bg-blur-alt);
    border-radius: 4px;
    transition: all 0.2s;
  }

  .compact-card:hover {
    background: var(--component-bg-hover);
    border-color: var(--component-text-primary-hover);
    transform: none;
  }

  .post-header-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }

  .compact-card .post-title {
    font-size: 1.1em;
    margin: 0;
    font-weight: 500;
    color: var(--component-text-primary);
    white-space: nowrap; /* 1. 强制一行 */
    overflow: hidden; /* 2. 隐藏溢出 */
    text-overflow: ellipsis; /* 3. 显示省略号 */
  }

  .compact-card .post-day {
    font-size: 1.2em;
    color: var(--component-text-secondary);
    font-family: monospace;
    margin-left: 10px;
    flex-shrink: 0;
  }

  .compact-card .post-tags {
    margin-top: 4px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-meta {
    font-size: 0.85em;
    color: var(--component-text-secondary);
    margin-bottom: 8px;
  }

  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: nowrap;
    margin-top: 8px;
    overflow-x: hidden;
  }

  .tag {
    background: var(--accent-color-bg);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.75em;
    color: var(--accent-color);
    display: inline-block;
    line-height: 1;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .tag.featured {
    font-weight: 600;
    background: var(--featured-bg);
    color: var(--featured);
  }

  .loading,
  .empty {
    text-align: center;
    padding: 60px;
    color: var(--component-text-secondary);
  }

  .initial-loading {
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05em;
  }

</style>

<!-- Client-side fetch + infinite scroll loader -->
<script
  type="module"
  define:vars={{
    expandText: t("blog.expand"),
    collapseText: t("blog.collapse"),
    daySuffix: t("blog.daySuffix"),
    featuredLabel: t("tag.featured"),
    initialPosts,
    initialPostsRequestUrl,
    initialFeaturedPosts,
    initialFeaturedTotal,
    locale,
  }}
>

  (function () {
    // 客户端API配置 - 直接指向3000端口的后端服务
    const API_BASE_URL = window.location.protocol + '//' + window.location.hostname + ':3000';
    const getApiUrl = (endpoint) => {
      endpoint = endpoint.startsWith('/') ? endpoint : `/${endpoint}`;
      return `${API_BASE_URL}${endpoint}`;
    };

    const perPage = 10;
    let page = initialPosts.length > 0 ? 1 : 0;
    let loading = false;
    let done = false;
    let loadedAny = initialPosts.length > 0;
    const featuredMap = new Map();
    let featuredPage = 1;
    let featuredTotal = initialFeaturedTotal;
    let featuredExpanded = false;

    const archive = document.getElementById("archive-list");
    const placeholder = document.getElementById("timeline-placeholder");
    const empty = document.getElementById("timeline-empty");
    const featuredSection = document.getElementById("featured-section");
    const featuredGrid = document.getElementById("featured-grid");
    const featuredToggle = document.getElementById("featured-toggle");

    function getUserLocale() {
      try {
        const stored = localStorage.getItem('locale');
        if (stored && stored !== 'follow') {
          return stored;
        }
      } catch (e) {
        // ignore localStorage errors
      }
      return navigator.language || 'zh-CN';
    }

    function logRequestUrl(stage, url) {
      let resolved = url;
      try {
        resolved = getApiUrl(url).toString();
      } catch (e) {
        // keep raw url when URL constructor cannot parse
      }
      console.info(`[blogs][${stage}] request raw:`, url);
      console.info(`[blogs][${stage}] request resolved:`, resolved);
    }

    // Log first-screen SSR request URL for parity with client pagination logs.
    logRequestUrl("ssr", initialPostsRequestUrl);

    async function loadFeaturedPosts(loadAll = false) {
      try {
        let url;
        if (loadAll) {
          url = `/api/posts?featured=true&timeline=desc&_ts=${Date.now()}`;
        } else {
          url = `/api/posts?featured=true&timeline=desc&page=${featuredPage}&perPage=3&_ts=${Date.now()}`;
        }
        logRequestUrl("featured", url);
        const res = await fetch(getApiUrl(url), { cache: "no-store" });
        if (res.ok) {
          const data = await res.json();
          const arr = Array.isArray(data) ? data : data.posts || [];
          arr.forEach(post => featuredMap.set(post.id, post));
          if (data.total !== undefined) {
            featuredTotal = data.total;
          }
          renderFeatured();
        }
      } catch (e) {
        console.error("[blogs] Error loading featured posts:", e);
      }
    }

    function resetFeaturedToggleState() {
      const featuredToggle = document.getElementById("featured-toggle");
      if (!featuredToggle) return;
      featuredToggle.dataset.expanded = "false";
      featuredToggle.textContent =
        featuredToggle.dataset.expandText || expandText;
    }

    // Use delegated handler so locale switches (DOM swaps) do not lose the click binding.
    if (!window.__chronicleBlogsFeaturedToggleBound) {
      window.__chronicleBlogsFeaturedToggleBound = true;
      document.addEventListener("click", async (event) => {
        if (!(event.target instanceof Element)) return;
        const btn = event.target.closest("#featured-toggle");
        if (!btn) return;

        const expanded = btn.dataset.expanded === "true";
        const next = !expanded;
        const expandLabel = btn.dataset.expandText || expandText;
        const collapseLabel = btn.dataset.collapseText || collapseText;

        btn.dataset.expanded = next ? "true" : "false";
        btn.textContent = next ? collapseLabel : expandLabel;
        
        // Update the featuredExpanded state
        featuredExpanded = next;
        
        // Load remaining featured posts when expanding
        if (next) {
          await loadFeaturedPosts(true);
        } else {
          // Collapse: re-render to show only first 3 posts
          renderFeatured();
        }
      });
    }

    if (initialPosts.length > 0) {
      if (featuredSection) featuredSection.style.display = "block";
      if (featuredToggle && featuredMap.size > 3) {
        featuredToggle.style.display = "inline-block";
        resetFeaturedToggleState();
      }
    }

    function escapeHtml(str) {
      return String(str || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function isFeaturedTag(tag) {
      return tag === "featured" || tag === "精选";
    }

    function sortTagsList(tags) {
      if (!Array.isArray(tags)) return [];
      return [...tags].sort((a, b) => {
        if (isFeaturedTag(a) && !isFeaturedTag(b)) return -1;
        if (!isFeaturedTag(a) && isFeaturedTag(b)) return 1;
        return String(a).localeCompare(String(b));
      });
    }

    function formatMonthNameISO(iso) {
      try {
        return new Date(iso).toLocaleString(getUserLocale(), {
          month: "short",
        });
      } catch (e) {
        return "";
      }
    }

    function ensureYearMonthContainer(year, monthName, monthIndex = null) {
      if (!archive) return null;
      let yearBlock = archive.querySelector(`.year-block[data-year="${year}"]`);
      if (!yearBlock) {
        // create year block and insert in descending order
        yearBlock = document.createElement("div");
        yearBlock.className = "year-block";
        yearBlock.setAttribute("data-year", String(year));
        const yHeader = document.createElement("div");
        yHeader.className = "year-header";
        yHeader.textContent = String(year);
        yearBlock.appendChild(yHeader);
        // insert maintaining descending year order
        const existing = Array.from(archive.querySelectorAll(".year-block"));
        let inserted = false;
        for (const eb of existing) {
          const ey = parseInt(eb.getAttribute("data-year") || "0", 10);
          if (ey < year) {
            archive.insertBefore(yearBlock, eb);
            inserted = true;
            break;
          }
        }
        if (!inserted) archive.appendChild(yearBlock);
      }
      let monthRow = Array.from(yearBlock.querySelectorAll(".month-row")).find(
        (m) => m.getAttribute("data-month") === monthName,
      );
      if (!monthRow) {
        monthRow = document.createElement("div");
        monthRow.className = "month-row";
        monthRow.setAttribute("data-month", monthName);
        if (monthIndex !== null)
          monthRow.setAttribute("data-month-index", String(monthIndex));
        const label = document.createElement("div");
        label.className = "month-label";
        const span = document.createElement("span");
        span.textContent = monthName;
        label.appendChild(span);
        const postsDiv = document.createElement("div");
        postsDiv.className = "month-posts";
        monthRow.appendChild(label);
        monthRow.appendChild(postsDiv);
        // insert monthRow in descending month-index order if siblings have index
        const siblings = Array.from(yearBlock.querySelectorAll(".month-row"));
        let insertedM = false;
        for (const s of siblings) {
          const si = s.getAttribute("data-month-index");
          if (si !== null && monthIndex !== null) {
            const sidx = parseInt(si, 10);
            if (sidx < monthIndex) {
              yearBlock.insertBefore(monthRow, s);
              insertedM = true;
              break;
            }
          }
        }
        if (!insertedM) yearBlock.appendChild(monthRow);
      }
      return monthRow.querySelector(".month-posts");
    }

    function appendPosts(arr) {
      arr.forEach((post) => {
        const d = new Date(post.date);
        const year = d.getFullYear();
        const monthName = formatMonthNameISO(post.date);
        const monthIndex = d.getMonth();
        const container = ensureYearMonthContainer(year, monthName, monthIndex);
        if (!container) return;

        const a = document.createElement("a");
        a.href = `/post/${post.id}`;
        a.style.textDecoration = "none";
        a.style.color = "inherit";
        a.setAttribute("data-post-date", post.date);
        const article = document.createElement("article");
        article.className = "post-card compact-card";
        const hdr = document.createElement("div");
        hdr.className = "post-header-row";
        const h4 = document.createElement("h4");
        h4.className = "post-title";
        h4.textContent = post.title;
        const day = document.createElement("span");
        day.className = "post-day";
        day.textContent = String(d.getDate()) + daySuffix;
        hdr.appendChild(h4);
        hdr.appendChild(day);
        article.appendChild(hdr);
        if (post.tags && post.tags.length) {
          const tagsDiv = document.createElement("div");
          tagsDiv.className = "post-tags";
          sortTagsList(post.tags).forEach((tag) => {
            const s = document.createElement("span");
            s.className = "tag" + (isFeaturedTag(tag) ? " featured" : "");
            s.textContent = "# " + (isFeaturedTag(tag) ? featuredLabel : tag);
            tagsDiv.appendChild(s);
          });
          article.appendChild(tagsDiv);
        }
        a.appendChild(article);

        // Insert into month container maintaining descending day order
        const newTs = d.getTime();
        let inserted = false;
        const siblings = Array.from(container.querySelectorAll("a"));
        for (const s of siblings) {
          const existingDate = s.getAttribute("data-post-date");
          const existingTs = existingDate
            ? new Date(existingDate).getTime()
            : 0;
          if (existingTs < newTs) {
            container.insertBefore(a, s);
            inserted = true;
            break;
          }
        }
        if (!inserted) container.appendChild(a);
      });
    }

    function renderFeatured() {
      // Re-fetch DOM elements each time to handle page reloads
      const featuredSection = document.getElementById("featured-section");
      const featuredGrid = document.getElementById("featured-grid");
      const featuredToggle = document.getElementById("featured-toggle");
      
      if (!featuredSection || !featuredGrid || !featuredToggle) return;
      const featured = Array.from(featuredMap.values()).sort(
        (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
      );
      
      console.log("[blogs] renderFeatured called:", { 
        featuredCount: featured.length, 
        expanded: featuredExpanded,
        total: featuredTotal 
      });
      
      if (!featured.length) {
        featuredSection.style.display = "none";
        return;
      }

      featuredSection.style.display = "block";
      const displayLimit = featuredExpanded ? featured.length : 3;
      const shouldShowToggle = featuredTotal > 3;
      
      featuredGrid.innerHTML = featured
        .slice(0, displayLimit)
        .map((post, idx) => {
          const tags = Array.isArray(post.tags) ? sortTagsList(post.tags) : [];
          const tagHtml = tags.length
            ? `<div class="post-tags">${tags.map((tag) => `<span class="tag${isFeaturedTag(tag) ? " featured" : ""}"># ${isFeaturedTag(tag) ? escapeHtml(featuredLabel) : escapeHtml(tag)}</span>`).join("")}</div>`
            : "";
          const dateText = new Date(post.date).toLocaleDateString(
            getUserLocale(),
          );
          return `<a href="/post/${encodeURIComponent(post.id)}" style="text-decoration:none; color:inherit;" class="featured-card">
          <article class="post-card featured-card">
            <div class="post-meta"><span class="post-date">${escapeHtml(dateText)}</span></div>
            <h3 class="post-title">${escapeHtml(post.title)}</h3>
            ${tagHtml}
          </article>
        </a>`;
        })
        .join("");

      featuredToggle.style.display = shouldShowToggle ? "inline-block" : "none";
      
      if (shouldShowToggle) {
        featuredToggle.dataset.expanded = featuredExpanded ? "true" : "false";
        featuredToggle.textContent = featuredExpanded ? 
          (featuredToggle.dataset.collapseText || collapseText) : 
          (featuredToggle.dataset.expandText || expandText);
      }
    }

    async function loadNext() {
      if (loading || done) return;
      loading = true;
      page += 1;
      try {
        const url = `/api/posts?page=${page}&perPage=${perPage}&timeline=desc&_ts=${Date.now()}`;
        logRequestUrl("csr", url);
        const res = await fetch(getApiUrl(url), { cache: "no-store" });
        if (!res.ok) {
          done = true;
          return;
        }
        const data = await res.json();
        const arr = Array.isArray(data) ? data : data.posts || [];
        if (page === 1 && placeholder) placeholder.style.display = "none";
        if (!arr.length) {
          done = true;
          if (!loadedAny && empty) empty.style.display = "block";
          return;
        }
        loadedAny = true;
        if (empty) empty.style.display = "none";
        appendPosts(arr);
        if (arr.length < perPage) done = true;
      } catch (e) {
        console.error("[blogs] Error loading posts:", e);
        done = true;
        if (page === 1 && placeholder) placeholder.style.display = "none";
        if (!loadedAny && empty) empty.style.display = "block";
      } finally {
        loading = false;
      }
    }

    // IntersectionObserver sentinel
    const sentinel = document.createElement("div");
    sentinel.id = "infinite-sentinel";
    if (archive) archive.appendChild(sentinel);

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((ent) => {
          if (ent.isIntersecting) loadNext();
        });
      },
      {
        root: document.querySelector(".main-content") || null,
        rootMargin: "200px",
      },
    );
    io.observe(sentinel);

    // Function to update all month labels with current locale
    function updateMonthLabels() {
      const monthLabels = document.querySelectorAll('.month-label span');
      monthLabels.forEach(label => {
        const monthRow = label.closest('.month-row');
        if (monthRow) {
          const monthIndex = monthRow.getAttribute('data-month-index');
          if (monthIndex !== null) {
            const currentYear = new Date().getFullYear();
            const year = monthRow.closest('.year-block')?.getAttribute('data-year');
            const date = new Date(parseInt(year), parseInt(monthIndex), 1);
            label.textContent = date.toLocaleString(getUserLocale(), { month: 'short' });
          }
        }
      });
    }

    // Listen for language changes - use a unique global flag to prevent duplicate binding
    if (!window.__chronicleBlogsLocaleListenerBound) {
      window.__chronicleBlogsLocaleListenerBound = true;
      
      window.addEventListener('storage', (e) => {
        if (e.key === 'locale') {
          // Reset expanded state when language changes
          featuredExpanded = false;
          updateMonthLabels();
          // Re-render featured to update button state
          // Re-fetch DOM elements after page reload
          const featuredSection = document.getElementById("featured-section");
          const featuredGrid = document.getElementById("featured-grid");
          const featuredToggle = document.getElementById("featured-toggle");
          if (featuredSection && featuredGrid && featuredToggle) {
            renderFeatured();
          }
        }
      });

      // Also listen for custom locale change events (from language switcher)
      document.addEventListener('localeChanged', () => {
        // Reset expanded state when language changes
        featuredExpanded = false;
        updateMonthLabels();
        // Re-render featured to update button state
        // Re-fetch DOM elements after page reload
        const featuredSection = document.getElementById("featured-section");
        const featuredGrid = document.getElementById("featured-grid");
        const featuredToggle = document.getElementById("featured-toggle");
        if (featuredSection && featuredGrid && featuredToggle) {
          renderFeatured();
        }
      });
    }

    // If SSR did not produce posts, fetch the first page on load.
    if (!initialPosts.length) loadNext();

    // Initialize featured posts from SSR data
    if (initialFeaturedPosts && initialFeaturedPosts.length > 0) {
      initialFeaturedPosts.forEach(post => featuredMap.set(post.id, post));
      renderFeatured();
    }

    // 智能预加载其他页面（博客列表页不预加载详情页）
    import('../utils/preload.ts').then(({ initPreloadSystem }) => {
      // 延迟执行预加载，避免影响首屏性能
      setTimeout(() => {
        initPreloadSystem();
      }, 2000);
    }).catch(err => {
      console.warn('[Preload] Failed to load preload module:', err);
    });
  })();
</script>