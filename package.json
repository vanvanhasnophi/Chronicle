{
  "name": "chronicle",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bash start.sh",
    "build": "bash scripts/build.sh full",
    "build:full": "bash scripts/build.sh full",
    "build:self-hosted": "bash scripts/build.sh self-hosted",
    "build:static": "bash scripts/build.sh static",
    "build:manager": "bash scripts/build.sh manager",
    "build:lite": "bash scripts/build.sh lite",
    "build:lite-local": "cd packages/template-astro && DATA_SOURCE=local npm run build",
    "migrate:posts": "node scripts/migrate_posts_dir.js",
    "release:check": "cd packages/manager && npx vue-tsc --noEmit",
    "typecheck": "tsc -b packages/shared packages/gen 2>/dev/null || true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3"
  }
}
